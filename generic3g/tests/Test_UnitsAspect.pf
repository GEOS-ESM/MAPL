#include "MAPL_TestErr.h"
#include "unused_dummy.H"

module Test_UnitsAspect
   use mapl3g_UnitsAspect
   use mapl3g_Field_API
   use mapl3g_FieldBundle_API
   use esmf
   use pfunit

   implicit none(type, external)

   character(len=*), parameter :: SRC_UNITS = "m"
   character(len=*), parameter :: DST_UNITS = "cm"

   interface initialize
      procedure :: initialize_field
      procedure :: initialize_bundle
   end interface initialize

contains

   @Test
   subroutine test_update_payload_field()
      type(ESMF_Field) :: field
      type(UnitsAspect) :: aspect
      character(len=:), allocatable :: units
      integer :: status
      
      call initialize(field, DST_UNITS, _RC)
      aspect=UnitsAspect(SRC_UNITS)
      call MAPL_FieldGet(field, units=units, _RC)
      @assertEqual(DST_UNITS, units, "Field units were not initialized correctly.")
      units=aspect%get_units(_RC)
      @assertEqual(SRC_UNITS, units, "Aspect units were not initialized correctly.")
      call aspect%update_payload(field, _RC)
      call MAPL_FieldGet(field, units=units, _RC)
      @assertEqual(SRC_UNITS, units, "Field units were not set correctly.")
      call ESMF_FieldDestroy(field, _RC)

   end subroutine test_update_payload_field

   @Test
   subroutine test_update_from_payload_field()
      type(ESMF_Field) :: field
      type(UnitsAspect) :: aspect
      character(len=:), allocatable :: units
      integer :: status

      call initialize(field, SRC_UNITS, _RC)
      aspect=UnitsAspect(DST_UNITS)
      call MAPL_FieldGet(field, units=units, _RC)
      @assertEqual(SRC_UNITS, units, "Field units were not initialized correctly.")
      units=aspect%get_units(_RC)
      @assertEqual(DST_UNITS, units, "Aspect units were not initialized correctly.")
      call aspect%update_from_payload(field, _RC)
      units=aspect%get_units(_RC)
      @assertEqual(SRC_UNITS, units, "Aspect units were not set correctly.")
      call ESMF_FieldDestroy(field, _RC)

   end subroutine test_update_from_payload_field

   @Test
   subroutine test_update_payload_bundle()
      type(ESMF_FieldBundle) :: bundle
      type(UnitsAspect) :: aspect
      character(len=:), allocatable :: units
      integer :: status

      call initialize(bundle, DST_UNITS, _RC)
      aspect=UnitsAspect(SRC_UNITS)
      call MAPL_FieldBundleGet(bundle, units=units, _RC)
      @assertEqual(DST_UNITS, units, "FieldBundle units were not initialized correctly.")
      units=aspect%get_units(_RC)
      @assertEqual(SRC_UNITS, units, "Aspect units were not initialized correctly.")
      call aspect%update_payload(bundle=bundle, _RC)
      call MAPL_FieldBundleGet(bundle, units=units, _RC)
      @assertEqual(SRC_UNITS, units, "FieldBundle units were not set correctly.")
      call ESMF_FieldBundleDestroy(bundle, _RC)
      
   end subroutine test_update_payload_bundle

   @Test
   subroutine test_update_from_payload_bundle()
      type(ESMF_FieldBundle) :: bundle
      type(UnitsAspect) :: aspect
      character(len=:), allocatable :: units
      integer :: status

      call initialize(bundle, SRC_UNITS, _RC)
      aspect=UnitsAspect(DST_UNITS)
      call MAPL_FieldBundleGet(bundle, units=units, _RC)
      @assertEqual(SRC_UNITS, units, "FieldBundle units were not initialized correctly.")
      units=aspect%get_units(_RC)
      @assertEqual(DST_UNITS, units, "Aspect units were not initialized correctly.")
      call aspect%update_from_payload(bundle=bundle, _RC)
      units=aspect%get_units(_RC)
      @assertEqual(SRC_UNITS, units, "Aspect units were not set correctly.")
      call ESMF_FieldBundleDestroy(bundle, _RC)

   end subroutine test_update_from_payload_bundle

   @Test
   subroutine test_mirroring_field()
      type(ESMF_Field) :: field
      type(UnitsAspect) :: aspect
      character(len=:), allocatable :: units
      integer :: status

      field=ESMF_FieldEmptyCreate(_RC)
      aspect=UnitsAspect()
      @assertTrue(aspect%is_mirror(), 'UnitsAspect should be mirrored before.')
      call aspect%update_payload(field, _RC)
      call MAPL_FieldGet(field, units=units, _RC)
      @assertFalse(allocated(units), 'units should not be allocated.')
      call aspect%update_from_payload(field, _RC)
      @assertTrue(aspect%is_mirror(), 'UnitsAspect should be mirrored after.')

   end subroutine test_mirroring_field

   @Test
   subroutine test_allocated_units_field()
      type(ESMF_Field) :: field
      type(UnitsAspect) :: aspect
      character(len=:), allocatable :: units
      integer :: status

      field=ESMF_FieldEmptyCreate(_RC)
      aspect=UnitsAspect(SRC_UNITS)
      @assertFalse(aspect%is_mirror(), 'UnitsAspect should not be mirrored before.')
      call aspect%update_payload(field, _RC)
      call MAPL_FieldGet(field, units=units, _RC)
      @assertTrue(allocated(units), 'units should be allocated.')
      call aspect%update_from_payload(field, _RC)
      @assertFalse(aspect%is_mirror(), 'UnitsAspect should not be mirrored after.')

   end subroutine test_allocated_units_field

   subroutine initialize_field(field, units, rc)
      type(ESMF_Field), intent(inout) :: field
      character(len=*), optional, intent(in) :: units
      integer, optional, intent(out) :: rc
      integer :: status

      field=ESMF_FieldEmptyCreate(_RC)
      if(.not. present(units)) then
         _RETURN(_SUCCESS)
      end if
      call MAPL_FieldSet(field, units=units, _RC)
      _RETURN(_SUCCESS)

   end subroutine initialize_field

   subroutine initialize_bundle(bundle, units, rc)
      type(ESMF_FieldBundle), intent(inout) :: bundle
      character(len=*), optional, intent(in) :: units
      integer, optional, intent(out) :: rc
      integer :: status

      bundle=ESMF_FieldBundleCreate(_RC)
      if(.not. present(units)) then
         _RETURN(_SUCCESS)
      end if
      call MAPL_FieldBundleSet(bundle, units=units, _RC)
      _RETURN(_SUCCESS)

   end subroutine initialize_bundle

end module Test_UnitsAspect
