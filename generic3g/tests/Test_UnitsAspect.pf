#include "MAPL_TestErr.h"
#include "unused_dummy.H"

module Test_UnitsAspect
   use mapl3g_UnitsAspect
   use mapl3g_Field_API
   use mapl3g_FieldBundle_API
   use esmf
   use pfunit

   implicit none(type, external)

   character(len=*), parameter :: SRC_UNITS = "m"
   character(len=*), parameter :: DST_UNITS = "cm"

contains

   @Test
   subroutine test_update_payload_units_field()
      type(ESMF_Field) :: field
      type(UnitsAspect) :: aspect
      character(len=:), allocatable :: units
      integer :: status
      
      field = ESMF_FieldEmptyCreate(_RC)
      call MAPL_FieldSet(field, units=DST_UNITS, _RC)
      aspect=UnitsAspect(SRC_UNITS)
      call aspect%update_payload(field=field, _RC)
      call MAPL_FieldGet(field, units=units, _RC)
      @assertEqual(SRC_UNITS, units, "Field units were not set correctly.")
      call ESMF_FieldDestroy(field, _RC)

   end subroutine test_update_payload_units_field

   @Test
   subroutine test_update_from_payload_units_field()
      type(ESMF_Field) :: field
      type(UnitsAspect) :: aspect
      character(len=:), allocatable :: units
      integer :: status

      field = ESMF_FieldEmptyCreate(_RC)
      call MAPL_FieldSet(field, units=SRC_UNITS, _RC)
      aspect=UnitsAspect(DST_UNITS)
      call aspect%update_from_payload(field=field, _RC)
      units=aspect%get_units(_RC)
      @assertEqual(SRC_UNITS, units, "Aspect units were not set correctly.")
      call ESMF_FieldDestroy(field, _RC)

   end subroutine test_update_from_payload_units_field

   @Test
   subroutine test_update_payload_units_bundle()
      type(ESMF_FieldBundle) :: bundle
      type(UnitsAspect) :: aspect
      character(len=:), allocatable :: units
      integer :: status

      bundle = ESMF_FieldBundleCreate(_RC)
      call MAPL_FieldBundleSet(bundle, units=DST_UNITS, _RC)
      aspect=UnitsAspect(SRC_UNITS)
      call aspect%update_payload(bundle=bundle, _RC)
      call MAPL_FieldBundleGet(bundle, units=units, _RC)
      @assertEqual(SRC_UNITS, units, "FieldBundle units were not set correctly.")
      call ESMF_FieldBundleDestroy(bundle, _RC)
      
   end subroutine test_update_payload_units_bundle

   @Test
   subroutine test_update_from_payload_units_bundle()
      type(ESMF_FieldBundle) :: bundle
      type(UnitsAspect) :: aspect
      character(len=:), allocatable :: units
      integer :: status

      bundle = ESMF_FieldBundleCreate(_RC)
      call MAPL_FieldBundleSet(bundle, units=SRC_UNITS, _RC)
      aspect=UnitsAspect(DST_UNITS)
      call aspect%update_from_payload(bundle=bundle, _RC)
      units=aspect%get_units(_RC)
      @assertEqual(SRC_UNITS, units, "Aspect units were not set correctly.")
      call ESMF_FieldBundleDestroy(bundle, _RC)

   end subroutine test_update_from_payload_units_bundle

   @Test
   subroutine test_update_nounits_field()
      type(ESMF_Field) :: field
      type(UnitsAspect) :: before, after
      character(len=:), allocatable :: units
      integer :: status

      field=ESMF_FieldEmptyCreate(_RC)
      before=UnitsAspect()
      after=UnitsAspect(DST_UNITS)
      
      call before%update_payload(field=field, _RC)
      call MAPL_FieldGet(field, units=units, _RC)
      @assertFalse(allocated(units), 'units should not be allocated.')
      if(allocated(units)) deallocate(units)

      call after%update_from_payload(field=field, _RC)
      @assertTrue(after%is_mirror(), 'UnitsAspect should be mirrored after.')
      call ESMF_FieldDestroy(field, _RC)

   end subroutine test_update_nounits_field

   @Test
   subroutine test_update_nounits_bundle()
      type(ESMF_FieldBundle) :: bundle
      type(UnitsAspect) :: before, after
      character(len=:), allocatable :: units
      integer :: status

      bundle=ESMF_FieldBundleCreate(_RC)
      before=UnitsAspect()
      after=UnitsAspect(DST_UNITS)
      
      call before%update_payload(bundle=bundle, _RC)
      call MAPL_FieldBundleGet(bundle, units=units, _RC)
      @assertFalse(allocated(units), 'units should not be allocated.')
      if(allocated(units)) deallocate(units)

      call after%update_from_payload(bundle=bundle, _RC)
      @assertTrue(after%is_mirror(), 'UnitsAspect should be mirrored after.')

   end subroutine test_update_nounits_bundle

   @Test
   subroutine test_update_units_field()
      type(ESMF_Field) :: field
      type(UnitsAspect) :: before
      character(len=:), allocatable :: units
      integer :: status

      field=ESMF_FieldEmptyCreate(_RC)
      call MAPL_FieldSet(field, units=DST_UNITS, _RC)
      before=UnitsAspect()

      call before%update_payload(field=field, _RC)
      call MAPL_FieldGet(field, units=units, _RC)
      @assertFalse(allocated(units), 'units should not be allocated.')
      call ESMF_FieldDestroy(field, _RC)

   end subroutine test_update_units_field

   @Test
   subroutine test_update_units_bundle()
      type(ESMF_FieldBundle) :: bundle
      type(UnitsAspect) :: before
      character(len=:), allocatable :: units
      integer :: status

      bundle=ESMF_FieldBundleCreate(_RC)
      call MAPL_FieldBundleSet(bundle, units=DST_UNITS, _RC)
      _HERE, 'Checking that units is set.'
      call MAPL_FieldBundleGet(bundle, units=units, _RC)
      _HERE, 'units: ', trim(units)
      before=UnitsAspect()
      _HERE, "is_mirror: ", before%is_mirror()

      if(allocated(units)) deallocate(units)
      call before%update_payload(bundle=bundle, _RC)
      call MAPL_FieldBundleGet(bundle, units=units, _RC)
      _HERE, "allocated: ", allocated(units)
      @assertFalse(allocated(units), 'units should not be allocated.')
      call ESMF_FieldBundleDestroy(bundle, _RC)

   end subroutine test_update_units_bundle

   @Test
   subroutine test_update_from_units_field()
      type(ESMF_Field) :: field
      type(UnitsAspect) :: before
      character(len=:), allocatable :: units
      integer :: status

      field=ESMF_FieldEmptyCreate(_RC)
      call MAPL_FieldSet(field, units=SRC_UNITS, _RC)
      before=UnitsAspect()

      call before%update_from_payload(field=field, _RC)
      units = before%get_units(_RC)    
      @assertTrue(allocated(units), 'units should be allocated.')
      @assertEqual(SRC_UNITS, units, 'units do not match field units.')
      call ESMF_FieldDestroy(field, _RC)

   end subroutine test_update_from_units_field

   @Test
   subroutine test_update_from_units_bundle()
      type(ESMF_FieldBundle) :: bundle
      type(UnitsAspect) :: before
      character(len=:), allocatable :: units
      integer :: status

      bundle=ESMF_FieldBundleCreate(_RC)
      call MAPL_FieldBundleSet(bundle, units=SRC_UNITS, _RC)
      before=UnitsAspect()

      call before%update_from_payload(bundle=bundle, _RC)
      units = before%get_units(_RC)    
      @assertTrue(allocated(units), 'units should be allocated.')
      @assertEqual(SRC_UNITS, units, 'units do not match field units.')
      call ESMF_FieldBundleDestroy(bundle, _RC)

   end subroutine test_update_from_units_bundle

end module Test_UnitsAspect
