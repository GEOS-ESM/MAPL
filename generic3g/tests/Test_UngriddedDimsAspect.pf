   @test(type=ESMF_TestMethod, npes=[1])
   subroutine test_update_payload_bundle_multiple_dims(this)
      ! Test updating an ESMF_FieldBundle from UngriddedDimsAspect with multiple dims
      class(ESMF_TestMethod), intent(inout) :: this
