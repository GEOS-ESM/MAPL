      ! Test unit computation for DELP denormalization (inverse)
      class(ESMF_TestMethod), intent(inout) :: this
      type(InverseNormalizationAspect) :: aspect

      aspect = InverseNormalizationAspect(aux_field_name='DELP', &
                                   scale_factor=0.102, &
                                   source_units='kg/m2')
      
      ! The aspect should compute target units internally
      ! For 'kg/m2' ÷ (DELP × 1/g) → 'kg/kg'
      ! This would be tested more thoroughly once update_from_payload works

      _UNUSED_DUMMY(this)

   end subroutine test_compute_denormalized_units_delp

   @test(type=ESMF_TestMethod, npes=[1])
   subroutine test_compute_denormalized_units_dz(this)
      ! Test unit computation for DZ denormalization (inverse)
      class(ESMF_TestMethod), intent(inout) :: this
      type(InverseNormalizationAspect) :: aspect

      aspect = InverseNormalizationAspect(aux_field_name='DZ', &
                                   scale_factor=1.0, &
                                   source_units='kg/m2')
      
      ! The aspect should compute target units internally
      ! For 'kg/m2' ÷ DZ → 'kg/m3'

      _UNUSED_DUMMY(this)

   end subroutine test_compute_denormalized_units_dz

   @test(type=ESMF_TestMethod, npes=[1])
   subroutine test_roundtrip_units_delp(this)
      ! Test that normalization → denormalization recovers original units
      class(ESMF_TestMethod), intent(inout) :: this
      
      ! This test verifies that the unit transformations are truly inverse
      ! Original: kg/kg
      ! Normalized: kg/m2 (via DELP with scale 1/g)
      ! Denormalized: kg/kg (should match original)
      
      ! For now, we just document the expected behavior
      ! Full integration testing will be done in Task 2.8

      _UNUSED_DUMMY(this)

   end subroutine test_roundtrip_units_delp

   @test(type=ESMF_TestMethod, npes=[1])
   subroutine test_roundtrip_units_dz(this)
      ! Test that normalization → denormalization recovers original units (DZ)
      class(ESMF_TestMethod), intent(inout) :: this
      
      ! This test verifies that the unit transformations are truly inverse
      ! Original: kg/m3
      ! Normalized: kg/m2 (via DZ with scale 1.0)
      ! Denormalized: kg/m3 (should match original)
      
      ! For now, we just document the expected behavior
      ! Full integration testing will be done in Task 2.8

      _UNUSED_DUMMY(this)

   end subroutine test_roundtrip_units_dz

end module Test_InverseNormalizationAspect
