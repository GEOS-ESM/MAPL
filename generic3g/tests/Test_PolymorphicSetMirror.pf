#include "MAPL_TestErr.h"
#include "unused_dummy.H"

module Test_PolymorphicSetMirror
   use funit
   use mapl3g_ExportNormalization
   use mapl3g_StateItemAspect
   use mapl_ErrorHandling
   use esmf
   use ESMF_TestMethod_mod
   implicit none

contains

   @test(type=ESMF_TestMethod, npes=[1])
   subroutine test_set_mirror_on_polymorphic_variable(this)
      ! Test that set_mirror(.false.) works on polymorphic class(StateItemAspect) variable
      class(ESMF_TestMethod), intent(inout) :: this
      class(StateItemAspect), allocatable :: aspect
      
      ! Create aspect through polymorphic variable (like VariableSpec does)
      allocate(aspect, source=ExportNormalization())
      
      ! Verify it starts as mirror=true (default)
      @assertTrue(aspect%is_mirror(), 'default should be mirror=true')
      
      ! Call set_mirror(.false.) on polymorphic variable
      call aspect%set_mirror(.false.)
      
      ! This is the key test - does it actually change?
      @assertFalse(aspect%is_mirror(), 'set_mirror(.false.) should change mirror flag')
      
      _UNUSED_DUMMY(this)
   end subroutine test_set_mirror_on_polymorphic_variable

   @test(type=ESMF_TestMethod, npes=[1])
   subroutine test_two_non_mirror_aspects_can_connect(this)
      ! Test that two ExportNormalizations with mirror=false can connect
      class(ESMF_TestMethod), intent(inout) :: this
      class(StateItemAspect), allocatable :: aspect1, aspect2
      logical :: can_connect
      
      ! Create both aspects with mirror=false (like VariableSpec does)
      allocate(aspect1, source=ExportNormalization())
      call aspect1%set_mirror(.false.)
      
      allocate(aspect2, source=ExportNormalization())
      call aspect2%set_mirror(.false.)
      
      ! Verify both are non-mirror
      @assertFalse(aspect1%is_mirror(), 'aspect1 should be non-mirror')
      @assertFalse(aspect2%is_mirror(), 'aspect2 should be non-mirror')
      
      ! Test if they can connect
      can_connect = aspect1%can_connect_to(aspect2)
      @assertTrue(can_connect, 'two default ExportNormalizations with mirror=false should connect')
      
      _UNUSED_DUMMY(this)
   end subroutine test_two_non_mirror_aspects_can_connect

end module Test_PolymorphicSetMirror
