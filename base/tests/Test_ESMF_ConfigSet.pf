#ifdef SUCCESSFUL_
#undef SUCCESSFUL_
#endif
#define SUCCESSFUL_(V, S) V==S

#ifdef SUCCESSFUL
#undef SUCCESSFUL
#endif
#define SUCCESSFUL(V) SUCCESSFUL_(V, SUCCESS)

module Test_ESMF_ConfigSet

   use pfunit
   use ESMF

   implicit none

   integer, parameter :: MAX_LENGTH = 1024
   integer, parameter :: SUCCESS = ESMF_SUCCESS
   integer, parameter :: FAILURE = SUCCESS - 1
   integer, parameter :: IOSUCCESS = 0
   integer, parameter :: CREATE_FILE_FAIL = -101
   integer, parameter :: WRITE_FILE_FAIL = -102
   integer, parameter :: NROWS = 2
   integer, parameter :: NCOLS = 3
   
   character(len=*), parameter :: EMPTY_STRING = ''
   character(len=*), parameter :: DIVIDER = ' :: '
   character(len=*), parameter :: LABEL1 = 'SwathGrid.Epoch_init:'
   character(len=*), parameter :: VALUE1 = "'20121113T000000'"
   character(len=*), parameter :: LABEL2 = 'SwathGrid.nc_Time:'
   character(len=*), parameter :: VALUE2 = "'time'"
   character(len=*), parameter :: LABEL3 = 'SwathGrid.nc_Longitude:'
   character(len=*), parameter :: VALUE3 = "'cell_across_swath'"

   type(ESMF_Config) :: gconfig
   character(len=MAX_LENGTH) :: gfilename
   integer :: fiounit = -1
   logical :: setup_complete = .FALSE.
   integer :: stat_setup

contains

   subroutine write_attributes(attributes_, iounit, rc)
      character(len=*), intent(in) :: attributes_(:, :)
      integer, intent(in) :: iounit
      integer, optional, intent(out) :: rc
      character, parameter :: DELIMITER = ' '
      character(len=MAX_LENGTH) :: line
      logical :: is_open
      integer :: ios, i

      inquire(unit=iounit, opened=is_open, iostat=ios)
      if(ios /= IOSUCCESS .or. .not. is_open) then
         if(present(rc)) rc = FAILURE
         return
      end if

      do i = 1, size(attributes_, 2)
         line = trim(attributes_(1, i)) // DELIMITER // trim(attributes_(2, i))
         write(unit=iounit, fmt='(A)', iostat=ios) trim(line)
         if(ios /= IOSUCCESS) exit
      end do
      if(present(rc)) rc=ios

   end subroutine write_attributes
         
   @before 
   subroutine setup()
      integer :: stat, iounit, ios
      character(len=MAX_LENGTH) :: attributes_(2, 3)

      setup_complete = .FALSE.
      stat_setup = -1

      gfilename = 'test'
      open(file=gfilename, newunit=iounit, iostat=ios)
      if(ios /= IOSUCCESS) then
         stat_setup = CREATE_FILE_FAIL
         return
      end if

      attributes_ = build_attributes()
      call write_attributes(attributes_, iounit, rc=stat)
      if(stat /= SUCCESS) then
         stat_setup = WRITE_FILE_FAIL
         return
      end if

      fiounit = iounit
      setup_complete = .TRUE.
      stat_setup = SUCCESS

   end subroutine setup

   @after
   subroutine teardown()
      integer :: iounit, ios
      
      iounit = fiounit
      close(iounit, status='DELETE', iostat=ios)
      
   end subroutine teardown

   @test
   subroutine test_setup()

      @assertTrue(stat_setup /= CREATE_FILE_FAIL, 'Failed to create file')
      @assertTrue(stat_setup /= WRITE_FILE_FAIL, 'Failed to write file')
      @assertTrue(stat_setup == SUCCESS, 'Setup failed.')
      @assertTrue(setup_complete, 'Setup did not complete.')

   end subroutine test_setup

   subroutine quick_test_ESMFConfigSetAttribute_array()
      type(ESMF_Config) :: config
      character(len=:), allocatable :: attribs(:, :)
      logical :: is_present, is_created, is_success
      integer :: stat, i

      config = ESMF_ConfigCreate(rc=stat)
      is_success = SUCCESSFUL(stat)
      @assertTrue(is_success, 'Failed to create ESMF_Config')
      if(.not. is_success) return

      is_created = ESMF_ConfigIsCreated(config, rc=stat)
      is_success = SUCCESSFUL(stat)
      @assertTrue(is_success, 'Failed to check ESMF_Config status')
      @assertTrue(is_created, 'ESMF_Config is not created.')
      if(.not. (is_created .and. is_success)) return

      attribs = build_attributes()

      do i = i, size(attribs, 2)
         call ESMF_ConfigSetAttribute(config, value=attribs(2, i), label=attribs(1,i), rc=stat)
         is_success = SUCCESSFUL(stat)
         @assertTrue(is_success, 'Failed to set attribute')
         if(.not. is_success) exit
      end do
      if(.not. is_success) return

      call ESMF_ConfigSetAttribute(config, value='19991231T235959', label=LABEL1, rc=stat)
      is_success = SUCCESSFUL(stat)
      @assertTrue(is_success, 'Failed to set (overwrite) LABEL1')
      if(.not. is_success) return

      call ESMF_ConfigFindLabel(config, label=LABEL2, isPresent=is_present, rc = stat)
      is_success = SUCCESSFUL(stat)
      @assertTrue(is_success, 'LABEL2 find failed.')
      @assertTrue(is_present, 'LABEL2 not found')

      if(is_created) call ESMF_ConfigDestroy(config, rc=stat)

   end subroutine quick_test_ESMFConfigSetAttribute_array

   @test
   subroutine quick_test_ESMFConfigSetAttribute_file()
      character(len=MAX_LENGTH) :: time_string
      integer :: stat
      character(len=MAX_LENGTH) :: filename
      logical :: is_created, is_present
      type(ESMF_Config) :: config

      config = ESMF_ConfigCreate(rc=stat)
      @assertTrue(stat == SUCCESS, 'Failed to create ESMF_Config')
      is_created = ESMF_ConfigIsCreated(config, rc=stat)
      @assertTrue(stat == SUCCESS, 'Failed to check ESMF_Config status')
      @assertTrue(is_created, 'ESMF_Config is not created.')

      filename = gfilename
      @assertTrue(len_trim(filename) > 0, 'Empty filename')
      if(len_trim(filename) == 0) return

      call ESMF_ConfigLoadFile(config, trim(filename), rc=stat)
      @assertTrue(stat == SUCCESS, 'Failed to load ESMF_Config: ' // trim(filename))

      ! set attribute for overwrite
      time_string = '19991231T235959'
      call ESMF_ConfigSetAttribute(config, value=time_string, label=LABEL1, rc=stat)
      @assertTrue(stat == SUCCESS, 'Failed to set (overwrite) LABEL1')

      call ESMF_ConfigFindLabel(config, label=LABEL2, isPresent=is_present, rc = stat)
      @assertTrue(is_present, 'LABEL2 not found')
      @assertTrue(stat == SUCCESS, 'Nonzero rc')

      if(is_created) call ESMF_ConfigDestroy(config, rc=stat)

   end subroutine quick_test_ESMFConfigSetAttribute_file

end module Test_ESMF_ConfigSet
