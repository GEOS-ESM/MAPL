/install*
!BUILD_INFO.rc.in

# If you build with spack libraries, you can get spack log files
spack*.log

# Nightly tests have log.* files
log.*

*.swp
*.swo
.DS_Store
*#
.#*
**/CVS/

/gFTL/

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

*.mod

*.log
.aider*
