#include "MAPL_TestErr.h"

module test_OS
   use mapl_os_mod
   use funit
   implicit none(type, external)

contains

   @test
   subroutine test_make_directory()
      character(*), parameter :: DIR = 'dir_a'
      integer :: status

      call MakeDirectory(DIR, _RC)
      @assert_that(DirectoryExists(DIR), is(true()))

      ! cleanup
      call RemoveDirectory(DIR, _RC)

   end subroutine test_make_directory

   @test
   subroutine test_push_directory()
      character(*), parameter :: SUBDIR = 'dir_a'
      integer :: status
      character(:), allocatable :: dir, current_dir

      current_dir = GetCurrentWorkingDirectory(_RC)
      call MakeDirectory(SUBDIR, _RC)
      call PushDirectory(SUBDIR, _RC)

      dir = GetCurrentWorkingDirectory(_RC)
      @assertEqual(PathJoin(current_dir, SUBDIR), dir)

      dir = PopDirectory(_RC)
      @assertEqual(current_dir, dir)

      dir = GetCurrentWorkingDirectory(_RC)
      @assertEqual(current_dir, dir)

      ! cleanup
      call RemoveDirectory(SUBDIR, _RC)
   end subroutine test_push_directory

   @test
   subroutine test_push_directory_sequence_a()
      character(*), parameter :: SUBDIR_A = 'dir_a'
      character(*), parameter :: SUBDIR_B = 'dir_b'
      integer :: status
      character(:), allocatable :: dir, current_dir

      current_dir = GetCurrentWorkingDirectory(_RC)
      call MakeDirectory(SUBDIR_A, _RC)
      call PushDirectory(SUBDIR_A, _RC)

      call MakeDirectory(SUBDIR_B, _RC)
      call PushDirectory(SUBDIR_B, _RC)
      dir = PopDirectory(_RC)
      @assertEqual(PathJoin(current_dir, SUBDIR_A), dir)

      dir = PopDirectory(_RC)
      @assertEqual(current_dir, dir)

      ! cleanup
      call RemoveDirectory(PathJoin(SUBDIR_A, SUBDIR_B), _RC)
      call RemoveDirectory(SUBDIR_A, _RC)
   end subroutine test_push_directory_sequence_a

   @test
   subroutine test_push_directory_sequence_b()
      character(*), parameter :: SUBDIR = 'dir_a'
      integer :: status
      character(:), allocatable :: dir, current_dir

      current_dir = GetCurrentWorkingDirectory(_RC)
      call MakeDirectory(SUBDIR, _RC)
      call PushDirectory(SUBDIR, _RC)

      call PushDirectory(_RC) ! back to where we started?
      dir = GetCurrentWorkingDirectory(_RC)
      @assertEqual(current_dir, dir)

      call PushDirectory(_RC) ! back to SUBDIR
      dir = GetCurrentWorkingDirectory(_RC)
      @assertEqual(PathJoin(current_dir,SUBDIR), dir)

      dir = PopDirectory(_RC)
      @assertEqual(current_dir, dir)

      dir = GetCurrentWorkingDirectory(_RC)
      @assertEqual(current_dir, dir)

      ! cleanup
      call RemoveDirectory(SUBDIR, _RC)
   end subroutine test_push_directory_sequence_b

   @test
   subroutine test_symlink()
      character(*), parameter :: SUBDIR = 'dir_a'
      character(*), parameter :: SYMDIR = 'dir_b'

      integer :: status

      call MakeDirectory(SUBDIR, _RC)
      call MakeSymbolicLink(src_path=SUBDIR, link_path=SYMDIR, _RC)

      @assert_that(DirectoryExists(SYMDIR), is(true()))

      call RemoveFile(SYMDIR, _RC)
      call RemoveDirectory(SUBDIR, _RC)

   end subroutine test_symlink

end module test_OS
