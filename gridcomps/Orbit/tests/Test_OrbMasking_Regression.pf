   @test(npes=[6], type=ESMF_TestMethod)
   subroutine test_cs_c48_equatorial_swath_6pe(this)
      class(ESMF_TestMethod), intent(inout) :: this
      type(ESMF_Grid) :: grid
      type(ESMF_VM) :: vm
      real(ESMF_KIND_R8), pointer :: lons(:,:), lats(:,:)
      integer(ESMF_KIND_I4), pointer :: mask(:,:)
      real(dp), pointer :: slons(:,:), slats(:,:)
      integer :: status, localPet, nobs
      integer, parameter :: IM = 48
      integer :: ref_mask(IM, IM, 6)
      
      call read_reference_mask('ref_cs_c48_equatorial_swath_6pe.txt', IM, IM, 6, ref_mask)
      
      grid = ESMF_GridCreateCubedSphere(IM, &
           staggerLocList=[ESMF_STAGGERLOC_CENTER], &
           coordSys=ESMF_COORDSYS_SPH_RAD, rc=status)
      @assertEqual(0, status)
      
      call ESMF_AttributeSet(grid, 'GridType', 'Cubed-Sphere', rc=status)
      @assertEqual(0, status)
      
      call ESMF_GridAddItem(grid, staggerloc=ESMF_STAGGERLOC_CENTER, &
                            itemflag=ESMF_GRIDITEM_MASK, rc=status)
      @assertEqual(0, status)
      
      call ESMF_GridGetCoord(grid, coordDim=1, staggerloc=ESMF_STAGGERLOC_CENTER, &
                             farrayPtr=lons, rc=status)
      @assertEqual(0, status)
      call ESMF_GridGetCoord(grid, coordDim=2, staggerloc=ESMF_STAGGERLOC_CENTER, &
                             farrayPtr=lats, rc=status)
      @assertEqual(0, status)
      
      call ESMF_GridGetItem(grid, staggerloc=ESMF_STAGGERLOC_CENTER, &
                            itemflag=ESMF_GRIDITEM_MASK, farrayPtr=mask, rc=status)
      @assertEqual(0, status)
      
      call orbits_swath(slons, slats, 'EQUATORIAL', [20240101, 20240101], &
                       [0, 120000], 3600, [500.0_dp, 500.0_dp], rc=status)
      @assertEqual(0, status)
      nobs = size(slons, 2)
      
      mask = 0
      call orb_swath_mask_lonlat(mask, IM, IM, real(lons, ESMF_KIND_R4), real(lats, ESMF_KIND_R4), &
                                slons, slats, nobs, 10, 10, -180.0, 180.0)
      
      ! Get local PE number to compare correct tile
      call ESMF_VMGetCurrent(vm, rc=status)
      @assertEqual(0, status)
      call ESMF_VMGet(vm, localPet=localPet, rc=status)
      @assertEqual(0, status)
      
      ! For CS with 6 PEs, each PE has one tile (localPet+1)
      @assertEqual(ref_mask(:, :, localPet+1), mask)
      
      deallocate(slons, slats)
      call ESMF_GridDestroy(grid, rc=status)
   end subroutine test_cs_c48_equatorial_swath_6pe

   !---------------------------------------------------------------------------
   ! TEST: Verify cubed-sphere C48 diagonal swath mask matches reference (6 PEs)
   !---------------------------------------------------------------------------
   @test(npes=[6], type=ESMF_TestMethod)
   subroutine test_cs_c48_diagonal_swath_6pe(this)
      class(ESMF_TestMethod), intent(inout) :: this
      type(ESMF_Grid) :: grid
      type(ESMF_VM) :: vm
      real(ESMF_KIND_R8), pointer :: lons(:,:), lats(:,:)
      integer(ESMF_KIND_I4), pointer :: mask(:,:)
      real(dp), pointer :: slons(:,:), slats(:,:)
      integer :: status, localPet, nobs
      integer, parameter :: IM = 48
      integer :: ref_mask(IM, IM, 6)
      
      call read_reference_mask('ref_cs_c48_diagonal_swath_6pe.txt', IM, IM, 6, ref_mask)
      
      grid = ESMF_GridCreateCubedSphere(IM, &
           staggerLocList=[ESMF_STAGGERLOC_CENTER], &
           coordSys=ESMF_COORDSYS_SPH_RAD, rc=status)
      @assertEqual(0, status)
      
      call ESMF_AttributeSet(grid, 'GridType', 'Cubed-Sphere', rc=status)
      @assertEqual(0, status)
      
      call ESMF_GridAddItem(grid, staggerloc=ESMF_STAGGERLOC_CENTER, &
                            itemflag=ESMF_GRIDITEM_MASK, rc=status)
      @assertEqual(0, status)
      
      call ESMF_GridGetCoord(grid, coordDim=1, staggerloc=ESMF_STAGGERLOC_CENTER, &
                             farrayPtr=lons, rc=status)
      @assertEqual(0, status)
      call ESMF_GridGetCoord(grid, coordDim=2, staggerloc=ESMF_STAGGERLOC_CENTER, &
                             farrayPtr=lats, rc=status)
      @assertEqual(0, status)
      
      call ESMF_GridGetItem(grid, staggerloc=ESMF_STAGGERLOC_CENTER, &
                            itemflag=ESMF_GRIDITEM_MASK, farrayPtr=mask, rc=status)
      @assertEqual(0, status)
      
      call orbits_swath(slons, slats, 'DIAGONAL', [20240101, 20240101], &
                       [0, 120000], 3600, [500.0_dp, 500.0_dp], rc=status)
      @assertEqual(0, status)
      nobs = size(slons, 2)
      
      mask = 0
      call orb_swath_mask_lonlat(mask, IM, IM, real(lons, ESMF_KIND_R4), real(lats, ESMF_KIND_R4), &
                                slons, slats, nobs, 10, 10, -180.0, 180.0)
      
      ! Get local PE number to compare correct tile
      call ESMF_VMGetCurrent(vm, rc=status)
      @assertEqual(0, status)
      call ESMF_VMGet(vm, localPet=localPet, rc=status)
      @assertEqual(0, status)
      
      ! For CS with 6 PEs, each PE has one tile (localPet+1)
      @assertEqual(ref_mask(:, :, localPet+1), mask)
      
      deallocate(slons, slats)
      call ESMF_GridDestroy(grid, rc=status)
   end subroutine test_cs_c48_diagonal_swath_6pe

end module Test_OrbMasking_Regression
