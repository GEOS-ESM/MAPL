   !---------------------------------------------------------------------------
   ! TEST: Verify lat-lon equatorial mask matches reference (1 PE)
   !---------------------------------------------------------------------------
   @test(npes=[1], type=ESMF_TestMethod)
   subroutine test_latlon_equatorial_1pe(this)
      class(ESMF_TestMethod), intent(inout) :: this
      type(ESMF_Grid) :: grid
      real(ESMF_KIND_R8), pointer :: lons(:,:), lats(:,:)
      integer(ESMF_KIND_I4), pointer :: mask(:,:)
      real(dp), pointer :: tlons(:), tlats(:)
      integer :: status, i, j
      integer :: lb(2), ub(2), ntiles
      integer, parameter :: IM_LL = 8, JM_LL = 6
      integer :: ref_mask(IM_LL, JM_LL, 1)
      
      ! Read reference mask from file
      call read_reference_mask('ref_latlon_8x6_equatorial_1pe.txt', &
                               IM_LL, JM_LL, 1, ref_mask)
      
      ! Create same grid as capture
      grid = ESMF_GridCreate1PeriDim( &
         maxIndex=[IM_LL, JM_LL], &
         coordSys=ESMF_COORDSYS_SPH_DEG, &
         indexflag=ESMF_INDEX_GLOBAL, &
         rc=status)
      @assertEqual(0, status)
      
      call ESMF_GridAddCoord(grid, staggerloc=ESMF_STAGGERLOC_CENTER, rc=status)
      @assertEqual(0, status)
      
      call ESMF_GridGetCoord(grid, coordDim=1, staggerloc=ESMF_STAGGERLOC_CENTER, &
                             farrayPtr=lons, rc=status)
      @assertEqual(0, status)
      call ESMF_GridGetCoord(grid, coordDim=2, staggerloc=ESMF_STAGGERLOC_CENTER, &
                             farrayPtr=lats, rc=status)
      @assertEqual(0, status)
      
      do j = 1, JM_LL
         do i = 1, IM_LL
            lons(i,j) = -135.0_ESMF_KIND_R8 + (i-1) * 45.0_ESMF_KIND_R8
            lats(i,j) = -50.0_ESMF_KIND_R8 + (j-1) * 20.0_ESMF_KIND_R8
         end do
      end do
      
      call ESMF_GridAddItem(grid, staggerloc=ESMF_STAGGERLOC_CENTER, &
                            itemflag=ESMF_GRIDITEM_MASK, rc=status)
      @assertEqual(0, status)
      call ESMF_GridGetItem(grid, staggerloc=ESMF_STAGGERLOC_CENTER, &
                            itemflag=ESMF_GRIDITEM_MASK, farrayPtr=mask, rc=status)
      @assertEqual(0, status)
      
      ! Same orbit as capture
      call orbits_track(tlons, tlats, 'EQUATORIAL', [20240101, 20240101], &
                        [0, 120000], 3600, status)
      @assertEqual(0, status)
      
      ! Compute mask with current implementation
      mask = 0
      call orb_mask_lonlat(mask, IM_LL, JM_LL, real(lons, ESMF_KIND_R4), real(lats, ESMF_KIND_R4), &
                           tlons, tlats, size(tlons), 10, -180.0, 180.0)
      
      ! Verify layout matches capture (1 PE, full grid)
      call ESMF_GridGet(grid, localDe=0, staggerloc=ESMF_STAGGERLOC_CENTER, &
                        exclusiveLBound=lb, exclusiveUBound=ub, rc=status)
      @assertEqual(0, status)
      @assertEqual(1, lb(1))
      @assertEqual(1, lb(2))
      @assertEqual(IM_LL, ub(1))
      @assertEqual(JM_LL, ub(2))
      
      call ESMF_GridGet(grid, tileCount=ntiles, rc=status)
      @assertEqual(0, status)
      @assertEqual(1, ntiles)
      
      ! Compare with reference
      @assertEqual(ref_mask(:,:,1), mask)
      
      call ESMF_GridDestroy(grid, rc=status)
   end subroutine test_latlon_equatorial_1pe

   !---------------------------------------------------------------------------
   ! TEST: Verify lat-lon diagonal mask matches reference (1 PE)
   !---------------------------------------------------------------------------
   @test(npes=[1], type=ESMF_TestMethod)
   subroutine test_latlon_8x6_diagonal_1pe(this)
      class(ESMF_TestMethod), intent(inout) :: this
      type(ESMF_Grid) :: grid
      real(ESMF_KIND_R8), pointer :: lons(:,:), lats(:,:)
      integer(ESMF_KIND_I4), pointer :: mask(:,:)
      real(dp), pointer :: tlons(:), tlats(:)
      integer :: status, i, j
      integer, parameter :: IM = 8, JM = 6
      integer :: ref_mask(IM, JM, 1)
      
      call read_reference_mask('ref_latlon_8x6_diagonal_1pe.txt', IM, JM, 1, ref_mask)
      
      grid = ESMF_GridCreate1PeriDim(maxIndex=[IM, JM], &
         coordSys=ESMF_COORDSYS_SPH_DEG, indexflag=ESMF_INDEX_GLOBAL, rc=status)
      @assertEqual(0, status)
      
      call ESMF_GridAddCoord(grid, staggerloc=ESMF_STAGGERLOC_CENTER, rc=status)
      @assertEqual(0, status)
      call ESMF_GridGetCoord(grid, coordDim=1, staggerloc=ESMF_STAGGERLOC_CENTER, &
                             farrayPtr=lons, rc=status)
      @assertEqual(0, status)
      call ESMF_GridGetCoord(grid, coordDim=2, staggerloc=ESMF_STAGGERLOC_CENTER, &
                             farrayPtr=lats, rc=status)
      @assertEqual(0, status)
      
      do j = 1, JM
         do i = 1, IM
            lons(i,j) = -135.0_ESMF_KIND_R8 + (i-1) * 45.0_ESMF_KIND_R8
            lats(i,j) = -50.0_ESMF_KIND_R8 + (j-1) * 20.0_ESMF_KIND_R8
         end do
      end do
      
      call ESMF_GridAddItem(grid, staggerloc=ESMF_STAGGERLOC_CENTER, &
                            itemflag=ESMF_GRIDITEM_MASK, rc=status)
      @assertEqual(0, status)
      call ESMF_GridGetItem(grid, staggerloc=ESMF_STAGGERLOC_CENTER, &
                            itemflag=ESMF_GRIDITEM_MASK, farrayPtr=mask, rc=status)
      @assertEqual(0, status)
      
      call orbits_track(tlons, tlats, 'DIAGONAL', [20240101, 20240101], &
                        [0, 120000], 3600, status)
      @assertEqual(0, status)
      
      mask = 0
      call orb_mask_lonlat(mask, IM, JM, real(lons, ESMF_KIND_R4), real(lats, ESMF_KIND_R4), &
                           tlons, tlats, size(tlons), 10, -180.0, 180.0)
      
      @assertEqual(ref_mask(:,:,1), mask)
      
      call ESMF_GridDestroy(grid, rc=status)
   end subroutine test_latlon_8x6_diagonal_1pe

