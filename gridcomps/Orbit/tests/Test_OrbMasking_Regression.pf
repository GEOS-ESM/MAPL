   !---------------------------------------------------------------------------
   ! TEST: Verify lat-lon 180x91 equatorial swath mask matches reference (1 PE)
   !---------------------------------------------------------------------------
   @test(npes=[1], type=ESMF_TestMethod)
   subroutine test_latlon_180x91_equatorial_swath_1pe(this)
      class(ESMF_TestMethod), intent(inout) :: this
      type(ESMF_Grid) :: grid
      real(ESMF_KIND_R8), pointer :: lons(:,:), lats(:,:)
      integer(ESMF_KIND_I4), pointer :: mask(:,:)
      real(dp), pointer :: slons(:,:), slats(:,:)
      integer :: status, nobs, i, j
      integer, parameter :: IM = 180, JM = 91
      integer :: ref_mask(IM, JM, 1)
      
      call read_reference_mask('ref_latlon_180x91_equatorial_swath_1pe.txt', IM, JM, 1, ref_mask)
      
      grid = ESMF_GridCreate1PeriDim(maxIndex=[IM, JM], &
           coordSys=ESMF_COORDSYS_SPH_DEG, &
           regDecomp=[1,1], indexflag=ESMF_INDEX_GLOBAL, rc=status)
      @assertEqual(0, status)
      
      call ESMF_GridAddCoord(grid, staggerloc=ESMF_STAGGERLOC_CENTER, rc=status)
      @assertEqual(0, status)
      
      call ESMF_AttributeSet(grid, 'GridType', 'LatLon', rc=status)
      @assertEqual(0, status)
      
      call ESMF_GridAddItem(grid, staggerloc=ESMF_STAGGERLOC_CENTER, &
                            itemflag=ESMF_GRIDITEM_MASK, rc=status)
      @assertEqual(0, status)
      
      call ESMF_GridGetCoord(grid, coordDim=1, staggerloc=ESMF_STAGGERLOC_CENTER, &
                             farrayPtr=lons, rc=status)
      @assertEqual(0, status)
      call ESMF_GridGetCoord(grid, coordDim=2, staggerloc=ESMF_STAGGERLOC_CENTER, &
                             farrayPtr=lats, rc=status)
      @assertEqual(0, status)
      
      ! Populate coordinates: -180 to +178°, -90 to 90°
      do j = 1, JM
         do i = 1, IM
            lons(i,j) = -180.0_ESMF_KIND_R8 + (i-1) * 2.0_ESMF_KIND_R8
            lats(i,j) = -90.0_ESMF_KIND_R8 + (j-1) * 2.0_ESMF_KIND_R8
         end do
      end do
      
      call ESMF_GridGetItem(grid, staggerloc=ESMF_STAGGERLOC_CENTER, &
                            itemflag=ESMF_GRIDITEM_MASK, farrayPtr=mask, rc=status)
      @assertEqual(0, status)
      
      call orbits_swath(slons, slats, 'EQUATORIAL', [20240101, 20240101], &
                       [0, 120000], 3600, [500.0_dp, 500.0_dp], rc=status)
      @assertEqual(0, status)
      nobs = size(slons, 2)
      
      mask = 0
      call orb_swath_mask_lonlat(mask, IM, JM, real(lons, ESMF_KIND_R4), real(lats, ESMF_KIND_R4), &
                                slons, slats, nobs, 10, 10, -180.0, 180.0)
      
      @assertEqual(ref_mask(:, :, 1), mask)
      
      deallocate(slons, slats)
      call ESMF_GridDestroy(grid, rc=status)
   end subroutine test_latlon_180x91_equatorial_swath_1pe

