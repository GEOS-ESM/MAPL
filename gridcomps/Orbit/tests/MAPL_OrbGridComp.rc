# Test configuration for MAPL Orbital Grid Component
# Minimal configuration with two test instruments

verbose: .false.
DT: 900
RUN_DT: 900

# Nominal Orbits Definition
# Format: Instrument  Satellite  Swath(km)  HaloWidth
Nominal_Orbits::
  TEST_INST1    EQUATORIAL    0.0      1
  TEST_INST2    POLAR       100.0      2
::

# Interpolation width (km) - used for track refinement
INTERPOLATION_WIDTH: 5.0
