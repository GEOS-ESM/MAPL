#include "MAPL_TestErr.h"
#include "unused_dummy.H"

module Test_FieldBundleGetByIndex
   use mapl_FieldBundleGetByIndex_mod
   use esmf
   use pfunit
   use ESMF_TestMethod_mod

   implicit none(type, external)

   type(ESMF_Grid) :: test_grid

contains

   @Before
   subroutine setUp(this)
      class(ESMF_TestMethod), intent(inout) :: this
      integer :: status
      integer, parameter :: MAX_INDEX(2) = [4, 4]
      integer, parameter :: REG_DECOMP(2) = [1, 1]

      test_grid = ESMF_GridCreate(regDecomp=REG_DECOMP, maxIndex=MAX_INDEX, _RC)

      _UNUSED_DUMMY(this)
   end subroutine setUp

   @After
   subroutine shutDown(this)
      class(ESMF_TestMethod), intent(inout) :: this
      integer :: status

      call ESMF_GridDestroy(test_grid, _RC)

      _UNUSED_DUMMY(this)
   end subroutine shutDown

   ! Basic: retrieve first field by index 1
   @Test(type=ESMF_TestMethod, npes=[1])
   subroutine test_get_first_field(this)
      class(ESMF_TestMethod), intent(inout) :: this
      type(ESMF_FieldBundle) :: bundle
      type(ESMF_Field) :: f1, f2, retrieved
      character(len=ESMF_MAXSTR) :: name
      integer :: status

      f1 = ESMF_FieldCreate(grid=test_grid, typekind=ESMF_TYPEKIND_R4, name='alpha', _RC)
      f2 = ESMF_FieldCreate(grid=test_grid, typekind=ESMF_TYPEKIND_R4, name='beta', _RC)
      bundle = ESMF_FieldBundleCreate(fieldList=[f1, f2], _RC)

      call FieldBundleGetByIndex(bundle, 1, retrieved, rc=status)
      @assertEqual(_SUCCESS, status, 'FieldBundleGetByIndex(1) failed')
      call ESMF_FieldGet(retrieved, name=name, _RC)
      @assertEqual('alpha', trim(name), 'Index 1 should return first field added')

      call ESMF_FieldDestroy(f1, _RC)
      call ESMF_FieldDestroy(f2, _RC)
      call ESMF_FieldBundleDestroy(bundle, _RC)
      _UNUSED_DUMMY(this)
   end subroutine test_get_first_field

   ! Basic: retrieve second field by index 2
   @Test(type=ESMF_TestMethod, npes=[1])
   subroutine test_get_second_field(this)
      class(ESMF_TestMethod), intent(inout) :: this
      type(ESMF_FieldBundle) :: bundle
      type(ESMF_Field) :: f1, f2, f3, retrieved
      character(len=ESMF_MAXSTR) :: name
      integer :: status

      f1 = ESMF_FieldCreate(grid=test_grid, typekind=ESMF_TYPEKIND_R4, name='one', _RC)
      f2 = ESMF_FieldCreate(grid=test_grid, typekind=ESMF_TYPEKIND_R4, name='two', _RC)
      f3 = ESMF_FieldCreate(grid=test_grid, typekind=ESMF_TYPEKIND_R4, name='three', _RC)
      bundle = ESMF_FieldBundleCreate(fieldList=[f1, f2, f3], _RC)

      call FieldBundleGetByIndex(bundle, 2, retrieved, rc=status)
      @assertEqual(_SUCCESS, status, 'FieldBundleGetByIndex(2) failed')
      call ESMF_FieldGet(retrieved, name=name, _RC)
      @assertEqual('two', trim(name), 'Index 2 should return second field added')

      call ESMF_FieldDestroy(f1, _RC)
      call ESMF_FieldDestroy(f2, _RC)
      call ESMF_FieldDestroy(f3, _RC)
      call ESMF_FieldBundleDestroy(bundle, _RC)
      _UNUSED_DUMMY(this)
   end subroutine test_get_second_field

   ! Verify add-order is respected (not alphabetical order)
   @Test(type=ESMF_TestMethod, npes=[1])
   subroutine test_add_order_preserved(this)
      class(ESMF_TestMethod), intent(inout) :: this
      type(ESMF_FieldBundle) :: bundle
      type(ESMF_Field) :: fz, fa, fm, retrieved
      character(len=ESMF_MAXSTR) :: name
      integer :: status

      ! Add in reverse-alphabetical order: z, a, m
      fz = ESMF_FieldCreate(grid=test_grid, typekind=ESMF_TYPEKIND_R4, name='zebra', _RC)
      fa = ESMF_FieldCreate(grid=test_grid, typekind=ESMF_TYPEKIND_R4, name='alpha', _RC)
      fm = ESMF_FieldCreate(grid=test_grid, typekind=ESMF_TYPEKIND_R4, name='middle', _RC)
      bundle = ESMF_FieldBundleCreate(fieldList=[fz, fa, fm], _RC)

      call FieldBundleGetByIndex(bundle, 1, retrieved, rc=status)
      @assertEqual(_SUCCESS, status)
      call ESMF_FieldGet(retrieved, name=name, _RC)
      @assertEqual('zebra', trim(name), 'Index 1 should be first field added (zebra)')

      call FieldBundleGetByIndex(bundle, 3, retrieved, rc=status)
      @assertEqual(_SUCCESS, status)
      call ESMF_FieldGet(retrieved, name=name, _RC)
      @assertEqual('middle', trim(name), 'Index 3 should be third field added (middle)')

      call ESMF_FieldDestroy(fz, _RC)
      call ESMF_FieldDestroy(fa, _RC)
      call ESMF_FieldDestroy(fm, _RC)
      call ESMF_FieldBundleDestroy(bundle, _RC)
      _UNUSED_DUMMY(this)
   end subroutine test_add_order_preserved

   ! Out-of-range index should raise an exception
   @Test(type=ESMF_TestMethod, npes=[1])
   subroutine test_out_of_range_index(this)
      class(ESMF_TestMethod), intent(inout) :: this
      type(ESMF_FieldBundle) :: bundle
      type(ESMF_Field) :: f1, retrieved
      integer :: status

      f1 = ESMF_FieldCreate(grid=test_grid, typekind=ESMF_TYPEKIND_R4, name='solo', _RC)
      bundle = ESMF_FieldBundleCreate(fieldList=[f1], _RC)

      call FieldBundleGetByIndex(bundle, 2, retrieved, rc=status)
      @assertExceptionRaised('fieldIndex out of range')

      call FieldBundleGetByIndex(bundle, 0, retrieved, rc=status)
      @assertExceptionRaised('fieldIndex out of range')

      call ESMF_FieldDestroy(f1, _RC)
      call ESMF_FieldBundleDestroy(bundle, _RC)
      _UNUSED_DUMMY(this)
   end subroutine test_out_of_range_index

   ! Iterate all fields by index and verify round-trip
   @Test(type=ESMF_TestMethod, npes=[1])
   subroutine test_iterate_all_fields(this)
      class(ESMF_TestMethod), intent(inout) :: this
      type(ESMF_FieldBundle) :: bundle
      integer, parameter :: N = 5
      type(ESMF_Field) :: fields(N), retrieved
      character(len=ESMF_MAXSTR) :: expected_names(N), name
      integer :: i, status

      expected_names = ['field_1', 'field_2', 'field_3', 'field_4', 'field_5']
      do i = 1, N
         fields(i) = ESMF_FieldCreate(grid=test_grid, typekind=ESMF_TYPEKIND_R4, &
              name=trim(expected_names(i)), _RC)
      end do
      bundle = ESMF_FieldBundleCreate(fieldList=fields, _RC)

      do i = 1, N
         call FieldBundleGetByIndex(bundle, i, retrieved, rc=status)
         @assertEqual(_SUCCESS, status, 'FieldBundleGetByIndex failed for index '//trim(expected_names(i)))
         call ESMF_FieldGet(retrieved, name=name, _RC)
         @assertEqual(trim(expected_names(i)), trim(name), 'Wrong field at index')
      end do

      do i = 1, N
         call ESMF_FieldDestroy(fields(i), _RC)
      end do
      call ESMF_FieldBundleDestroy(bundle, _RC)
      _UNUSED_DUMMY(this)
   end subroutine test_iterate_all_fields

end module Test_FieldBundleGetByIndex
