#define I_AM_PFUNIT
#include "MAPL_ErrLog.h"

module Test_MeshGeomFactory
   use pfunit
   use esmf_TestMethod_mod ! mapl
   use mapl3g_GeomSpec
   use mapl3g_MeshGeomFactory
   use mapl3g_MeshGeomSpec
   use mapl3g_MeshDecomposition
   use mapl3g_MeshTestHelper
   use gftl2_StringVector
   use mapl3g_StringDictionary
   use esmf
   implicit none

contains

   @test(type=ESMF_TestMethod, npes=[1])
   subroutine test_factory_supports_mesh_spec(this)
      class(ESMF_TestMethod), intent(inout) :: this
      
      type(MeshGeomFactory) :: factory
      type(MeshGeomSpec) :: mesh_spec
      type(MeshDecomposition) :: decomp
      logical :: supports
      
      _UNUSED_DUMMY(this)
      
      decomp = MeshDecomposition([1])
      mesh_spec = MeshGeomSpec(4, 1, decomp)
      
      supports = factory%supports_spec(mesh_spec)
      @assertTrue(supports)
      
   end subroutine test_factory_supports_mesh_spec

   @test(type=ESMF_TestMethod, npes=[1])
   subroutine test_factory_supports_mesh_hconfig(this)
      class(ESMF_TestMethod), intent(inout) :: this
      
      type(MeshGeomFactory) :: factory
      type(ESMF_HConfig) :: hconfig
      integer :: status
      logical :: supports
      
      _UNUSED_DUMMY(this)
      
      ! Test mesh HConfig with file
      hconfig = ESMF_HConfigCreate(content="{class: mesh, file: 'test.nc'}", rc=status)
      @assert_that(status, is(0))
      
      supports = factory%supports_hconfig(hconfig, rc=status)
      @assert_that(status, is(0))
      @assertTrue(supports)
      
      call ESMF_HConfigDestroy(hconfig, rc=status)
      @assert_that(status, is(0))
      
   end subroutine test_factory_supports_mesh_hconfig

   @test(type=ESMF_TestMethod, npes=[1])
   subroutine test_factory_does_not_support_locstream(this)
      class(ESMF_TestMethod), intent(inout) :: this
      
      type(MeshGeomFactory) :: factory
      type(ESMF_HConfig) :: hconfig
      integer :: status
      logical :: supports
      
      _UNUSED_DUMMY(this)
      
      ! Test that locstream is NOT supported
      hconfig = ESMF_HConfigCreate(content="{class: locstream, lon: [0.0], lat: [0.0]}", rc=status)
      @assert_that(status, is(0))
      
      supports = factory%supports_hconfig(hconfig, rc=status)
      @assert_that(status, is(0))
      @assertFalse(supports)
      
      call ESMF_HConfigDestroy(hconfig, rc=status)
      @assert_that(status, is(0))
      
   end subroutine test_factory_does_not_support_locstream

   @test(type=ESMF_TestMethod, npes=[1])
   subroutine test_make_gridded_dims(this)
      class(ESMF_TestMethod), intent(inout) :: this
      
      type(MeshGeomFactory) :: factory
      type(MeshGeomSpec) :: mesh_spec
      type(MeshDecomposition) :: decomp
      type(StringVector) :: gridded_dims
      integer :: status
      
      _UNUSED_DUMMY(this)
      
      decomp = MeshDecomposition([1])
      mesh_spec = MeshGeomSpec(4, 1, decomp)
      
      gridded_dims = factory%make_gridded_dims(mesh_spec, rc=status)
      @assert_that(status, is(0))
      @assert_that(int(gridded_dims%size()), is(1))
      @assert_that(gridded_dims%of(1), is("ncells"))
      
   end subroutine test_make_gridded_dims

   @test(type=ESMF_TestMethod, npes=[1])
   subroutine test_make_variable_attributes(this)
      class(ESMF_TestMethod), intent(inout) :: this
      
      type(MeshGeomFactory) :: factory
      type(MeshGeomSpec) :: mesh_spec
      type(MeshDecomposition) :: decomp
      type(StringDictionary) :: attrs
      integer :: status
      
      _UNUSED_DUMMY(this)
      
      decomp = MeshDecomposition([1])
      mesh_spec = MeshGeomSpec(4, 1, decomp)
      
      attrs = factory%make_variable_attributes(mesh_spec, rc=status)
      @assert_that(status, is(0))
      
      ! For now, just verify it returns successfully
      ! TODO: Add actual attribute checking when we understand StringDictionary API
      
   end subroutine test_make_variable_attributes

   @test(type=ESMF_TestMethod, npes=[1])
   subroutine test_create_simple_quad_mesh(this)
      class(ESMF_TestMethod), intent(inout) :: this
      
      type(MeshGeomFactory) :: factory
      type(MeshGeomSpec) :: mesh_spec
      type(ESMF_Geom) :: geom
      type(ESMF_Mesh) :: mesh
      type(ESMF_GeomType_Flag) :: geomtype
      type(ESMF_HConfig) :: hconfig
      integer :: status
      integer :: nodeCount, elementCount
      character(len=256) :: filename
      character(len=512) :: hconfig_str
      
      _UNUSED_DUMMY(this)
      
      ! Create mesh file
      filename = 'test_simple_quad.nc'
      call create_simple_quad_file(filename, rc=status)
      @assert_that(status, is(0))
      
      ! Create mesh spec from HConfig pointing to file
      write(hconfig_str, '(A,A,A)') "{class: mesh, file: '", trim(filename), "'}"
      hconfig = ESMF_HConfigCreate(content=trim(hconfig_str), rc=status)
      @assert_that(status, is(0))
      
      mesh_spec = make_MeshGeomSpec(hconfig, rc=status)
      @assert_that(status, is(0))
      
      call ESMF_HConfigDestroy(hconfig, rc=status)
      @assert_that(status, is(0))
      
      ! Create the ESMF geometry
      geom = factory%make_geom(mesh_spec, rc=status)
      @assert_that(status, is(0))
      
      ! Verify it's a mesh geometry
      call ESMF_GeomGet(geom, geomtype=geomtype, rc=status)
      @assert_that(status, is(0))
      @assertTrue(geomtype == ESMF_GEOMTYPE_MESH)
      
      ! Get the mesh and verify node/element counts
      call ESMF_GeomGet(geom, mesh=mesh, rc=status)
      @assert_that(status, is(0))
      
      call ESMF_MeshGet(mesh, nodeCount=nodeCount, elementCount=elementCount, rc=status)
      @assert_that(status, is(0))
      @assert_that(nodeCount, is(4))
      @assert_that(elementCount, is(1))
      
      ! Clean up
      call cleanup_test_file(filename, rc=status)
      
   end subroutine test_create_simple_quad_mesh

   @test(type=ESMF_TestMethod, npes=[1])
   subroutine test_create_triangle_mesh(this)
      class(ESMF_TestMethod), intent(inout) :: this
      
      type(MeshGeomFactory) :: factory
      type(MeshGeomSpec) :: mesh_spec
      type(ESMF_Geom) :: geom
      type(ESMF_Mesh) :: mesh
      type(ESMF_HConfig) :: hconfig
      integer :: status
      integer :: nodeCount, elementCount
      character(len=256) :: filename
      character(len=512) :: hconfig_str
      
      _UNUSED_DUMMY(this)
      
      ! Create mesh file
      filename = 'test_simple_triangle.nc'
      call create_simple_triangle_file(filename, rc=status)
      @assert_that(status, is(0))
      
      ! Create mesh spec from HConfig pointing to file
      write(hconfig_str, '(A,A,A)') "{class: mesh, file: '", trim(filename), "'}"
      hconfig = ESMF_HConfigCreate(content=trim(hconfig_str), rc=status)
      @assert_that(status, is(0))
      
      mesh_spec = make_MeshGeomSpec(hconfig, rc=status)
      @assert_that(status, is(0))
      
      call ESMF_HConfigDestroy(hconfig, rc=status)
      @assert_that(status, is(0))
      
      ! Create the ESMF geometry
      geom = factory%make_geom(mesh_spec, rc=status)
      @assert_that(status, is(0))
      
      ! Verify mesh was created correctly
      call ESMF_GeomGet(geom, mesh=mesh, rc=status)
      @assert_that(status, is(0))
      
      call ESMF_MeshGet(mesh, nodeCount=nodeCount, elementCount=elementCount, rc=status)
      @assert_that(status, is(0))
      @assert_that(nodeCount, is(3))
      @assert_that(elementCount, is(1))
      
      ! Clean up
      call cleanup_test_file(filename, rc=status)
      
   end subroutine test_create_triangle_mesh

