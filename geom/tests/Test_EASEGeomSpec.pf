#define I_AM_PFUNIT
#include "MAPL_ErrLog.h"

module Test_EASEGeomSpec
   use pfunit
   use funit
   use esmf_TestMethod_mod
   use mapl3g_EASEGeomSpec
   use mapl3g_EASEDecomposition
   use esmf
   implicit none

contains

   ! ------------------------------------------------------------------
   ! Test that EASEGeomSpec can be constructed from a grid name and
   ! returns the correct dimensions.
   @test(type=ESMF_TestMethod, npes=[1])
   subroutine test_new_EASEGeomSpec_v2_M09(this)
      class(ESMF_TestMethod), intent(inout) :: this

      type(EASEGeomSpec) :: spec
      type(EASEDecomposition) :: decomp
      integer :: status

      decomp = make_EASEDecomposition([3856, 1624], rc=status)
      @assert_that(status, is(0))

      spec = EASEGeomSpec('EASEv2_M09', decomp, rc=status)
      @assert_that(status, is(0))

      @assert_that(spec%get_im_world(), is(3856))
      @assert_that(spec%get_jm_world(), is(1624))
   end subroutine test_new_EASEGeomSpec_v2_M09

   ! ------------------------------------------------------------------
   @test(type=ESMF_TestMethod, npes=[1])
   subroutine test_new_EASEGeomSpec_v1_M36(this)
      class(ESMF_TestMethod), intent(inout) :: this

      type(EASEGeomSpec) :: spec
      type(EASEDecomposition) :: decomp
      integer :: status

      decomp = make_EASEDecomposition([963, 408], rc=status)
      @assert_that(status, is(0))

      spec = EASEGeomSpec('EASEv1_M36', decomp, rc=status)
      @assert_that(status, is(0))

      @assert_that(spec%get_im_world(), is(963))
      @assert_that(spec%get_jm_world(), is(408))
   end subroutine test_new_EASEGeomSpec_v1_M36

   ! ------------------------------------------------------------------
   ! Test equality
   @test(type=ESMF_TestMethod, npes=[1])
   subroutine test_equal_to(this)
      class(ESMF_TestMethod), intent(inout) :: this

      type(EASEGeomSpec) :: spec1, spec2, spec3
      type(EASEDecomposition) :: decomp09, decomp36
      integer :: status

      decomp09 = make_EASEDecomposition([3856, 1624], rc=status)
      @assert_that(status, is(0))
      decomp36 = make_EASEDecomposition([964, 406], rc=status)
      @assert_that(status, is(0))

      spec1 = EASEGeomSpec('EASEv2_M09', decomp09, rc=status)
      @assert_that(status, is(0))
      spec2 = EASEGeomSpec('EASEv2_M09', decomp09, rc=status)
      @assert_that(status, is(0))
      spec3 = EASEGeomSpec('EASEv2_M36', decomp36, rc=status)
      @assert_that(status, is(0))

      @assert_that(spec1 == spec2, is(.true.))
      @assert_that(spec1 == spec3, is(.false.))
   end subroutine test_equal_to

   ! ------------------------------------------------------------------
   ! Test supports_hconfig
   @test(type=ESMF_TestMethod, npes=[1])
   subroutine test_supports_hconfig(this)
      class(ESMF_TestMethod), intent(inout) :: this

      type(EASEGeomSpec) :: spec
      type(ESMF_HConfig) :: hconfig
      integer :: status
      logical :: supports

      ! Valid EASE hconfig
      hconfig = ESMF_HConfigCreate( &
           & content='{class: ease, grid_name: EASEv2_M09}', rc=status)
      @assert_that(status, is(0))
      supports = spec%supports(hconfig, rc=status)
      @assert_that(status, is(0))
      @assert_that(supports, is(.true.))
      call ESMF_HConfigDestroy(hconfig, rc=status)

      ! Wrong class
      hconfig = ESMF_HConfigCreate( &
           & content='{class: latlon, im_world: 12, jm_world: 6}', rc=status)
      @assert_that(status, is(0))
      supports = spec%supports(hconfig, rc=status)
      @assert_that(status, is(0))
      @assert_that(supports, is(.false.))
      call ESMF_HConfigDestroy(hconfig, rc=status)

   end subroutine test_supports_hconfig

   ! ------------------------------------------------------------------
   ! Test make_EASEGeomSpec from HConfig — auto VM decomposition
   @test(type=ESMF_TestMethod, npes=[1])
   subroutine test_make_from_hconfig_auto(this)
      class(ESMF_TestMethod), intent(inout) :: this

      type(EASEGeomSpec) :: spec
      type(ESMF_HConfig) :: hconfig
      integer :: status

      hconfig = ESMF_HConfigCreate( &
           & content='{class: ease, grid_name: EASEv2_M36}', rc=status)
      @assert_that(status, is(0))

      spec = make_EASEGeomSpec(hconfig, rc=status)
      @assert_that(status, is(0))
      @assert_that(spec%get_im_world(), is(964))
      @assert_that(spec%get_jm_world(), is(406))

      call ESMF_HConfigDestroy(hconfig, rc=status)
   end subroutine test_make_from_hconfig_auto

   ! ------------------------------------------------------------------
   ! Test make_EASEGeomSpec from HConfig — inline ims/jms sequences
   @test(type=ESMF_TestMethod, npes=[1])
   subroutine test_make_from_hconfig_inline_ims_jms(this)
      class(ESMF_TestMethod), intent(inout) :: this

      type(EASEGeomSpec) :: spec
      type(EASEDecomposition) :: decomp
      type(ESMF_HConfig) :: hconfig
      integer, allocatable :: ims(:), jms(:)
      integer :: status

      ! Use a tiny 4-column x 3-row toy grid (EASEv2_M36 is 964x406;
      ! we pass explicit ims/jms so the actual values don't need to
      ! sum to 964/406 — the spec only checks grid_name via ease_extent.)
      hconfig = ESMF_HConfigCreate( &
           & content='{class: ease, grid_name: EASEv2_M36, ims: [482, 482], jms: [203, 203]}', &
           & rc=status)
      @assert_that(status, is(0))

      spec = make_EASEGeomSpec(hconfig, rc=status)
      @assert_that(status, is(0))

      decomp = spec%get_decomposition()
      ims = decomp%get_lon_distribution()
      jms = decomp%get_lat_distribution()

      @assert_that(size(ims), is(2))
      @assert_that(ims(1), is(482))
      @assert_that(ims(2), is(482))
      @assert_that(size(jms), is(2))
      @assert_that(jms(1), is(203))
      @assert_that(jms(2), is(203))

      call ESMF_HConfigDestroy(hconfig, rc=status)
   end subroutine test_make_from_hconfig_inline_ims_jms

   ! ------------------------------------------------------------------
   ! Test make_EASEGeomSpec from HConfig — nx/ny topology
   @test(type=ESMF_TestMethod, npes=[1])
   subroutine test_make_from_hconfig_topology(this)
      class(ESMF_TestMethod), intent(inout) :: this

      type(EASEGeomSpec) :: spec
      type(EASEDecomposition) :: decomp
      type(ESMF_HConfig) :: hconfig
      integer, allocatable :: ims(:), jms(:)
      integer :: status

      hconfig = ESMF_HConfigCreate( &
           & content='{class: ease, grid_name: EASEv2_M36, nx: 2, ny: 2}', &
           & rc=status)
      @assert_that(status, is(0))

      spec = make_EASEGeomSpec(hconfig, rc=status)
      @assert_that(status, is(0))

      decomp = spec%get_decomposition()
      ims = decomp%get_lon_distribution()
      jms = decomp%get_lat_distribution()

      ! nx=2 => 2 lon tiles; ny=2 => 2 lat tiles
      @assert_that(size(ims), is(2))
      @assert_that(size(jms), is(2))
      @assert_that(sum(ims), is(964))
      @assert_that(sum(jms), is(406))

      call ESMF_HConfigDestroy(hconfig, rc=status)
   end subroutine test_make_from_hconfig_topology

   ! ------------------------------------------------------------------
   ! Test make_EASEGeomSpec from HConfig — file-based ims/jms
   @test(type=ESMF_TestMethod, npes=[1])
   subroutine test_make_from_hconfig_file_ims_jms(this)
      class(ESMF_TestMethod), intent(inout) :: this

      type(EASEGeomSpec) :: spec
      type(EASEDecomposition) :: decomp
      type(ESMF_HConfig) :: hconfig
      integer, allocatable :: ims(:), jms(:)
      integer :: status, unit

      ! Write temporary YAML distribution files
      open(newunit=unit, file='test_ims.yaml', status='replace', action='write')
      write(unit, '(a)') 'ims: [482, 482]'
      close(unit)

      open(newunit=unit, file='test_jms.yaml', status='replace', action='write')
      write(unit, '(a)') 'jms: [203, 203]'
      close(unit)

      hconfig = ESMF_HConfigCreate( &
           & content='{class: ease, grid_name: EASEv2_M36, ims_file: test_ims.yaml, jms_file: test_jms.yaml}', &
           & rc=status)
      @assert_that(status, is(0))

      spec = make_EASEGeomSpec(hconfig, rc=status)
      @assert_that(status, is(0))

      decomp = spec%get_decomposition()
      ims = decomp%get_lon_distribution()
      jms = decomp%get_lat_distribution()

      @assert_that(size(ims), is(2))
      @assert_that(ims(1), is(482))
      @assert_that(ims(2), is(482))
      @assert_that(size(jms), is(2))
      @assert_that(jms(1), is(203))
      @assert_that(jms(2), is(203))

      call ESMF_HConfigDestroy(hconfig, rc=status)

      ! Clean up temporary files
      open(newunit=unit, file='test_ims.yaml', status='old')
      close(unit, status='delete')
      open(newunit=unit, file='test_jms.yaml', status='old')
      close(unit, status='delete')

   end subroutine test_make_from_hconfig_file_ims_jms

   ! ------------------------------------------------------------------
   ! Verify the 1D default decomposition on multiple PEs:
   ! all PEs should stripe along longitude (size(ims)==npes, size(jms)==1).
   @test(type=ESMF_TestMethod, npes=[4])
   subroutine test_auto_decomp_is_1d(this)
      class(ESMF_TestMethod), intent(inout) :: this

      type(EASEDecomposition) :: decomp
      integer, allocatable :: ims(:), jms(:)
      integer :: status

      decomp = make_EASEDecomposition([964, 406], rc=status)
      @assert_that(status, is(0))

      ims = decomp%get_lon_distribution()
      jms = decomp%get_lat_distribution()

      ! 1D decomposition: 4 lon tiles, 1 lat tile
      @assert_that(size(ims), is(4))
      @assert_that(size(jms), is(1))
      @assert_that(sum(ims), is(964))
      @assert_that(sum(jms), is(406))
   end subroutine test_auto_decomp_is_1d

   ! ------------------------------------------------------------------
   ! Same check through the hconfig path with no decomp keys.
   @test(type=ESMF_TestMethod, npes=[4])
   subroutine test_make_from_hconfig_auto_is_1d(this)
      class(ESMF_TestMethod), intent(inout) :: this

      type(EASEGeomSpec) :: spec
      type(EASEDecomposition) :: decomp
      type(ESMF_HConfig) :: hconfig
      integer, allocatable :: ims(:), jms(:)
      integer :: status

      hconfig = ESMF_HConfigCreate( &
           & content='{class: ease, grid_name: EASEv2_M36}', rc=status)
      @assert_that(status, is(0))

      spec = make_EASEGeomSpec(hconfig, rc=status)
      @assert_that(status, is(0))

      decomp = spec%get_decomposition()
      ims = decomp%get_lon_distribution()
      jms = decomp%get_lat_distribution()

      ! Auto decomposition with 4 PEs must be 1D: [4, 1]
      @assert_that(size(ims), is(4))
      @assert_that(size(jms), is(1))
      @assert_that(sum(ims), is(964))
      @assert_that(sum(jms), is(406))

      call ESMF_HConfigDestroy(hconfig, rc=status)
   end subroutine test_make_from_hconfig_auto_is_1d

end module Test_EASEGeomSpec
