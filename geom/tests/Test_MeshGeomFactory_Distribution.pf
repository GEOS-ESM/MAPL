#define I_AM_PFUNIT
#include "MAPL_ErrLog.h"

module Test_MeshGeomFactory_Distribution
   use pfunit
   use esmf_TestMethod_mod ! mapl
   use mapl3g_MeshGeomFactory
   use mapl3g_MeshGeomSpec
   use mapl3g_MeshDecomposition
   use mapl3g_GeomSpec
   use mapl3g_MeshTestHelper
   use mapl_ErrorHandlingMod
   use pfio
   use esmf
   use, intrinsic :: iso_fortran_env, only: REAL64
   implicit none

contains

   ! Test automatic distribution path (uniform decomposition)
   @test(type=ESMF_TestMethod, npes=[4])
   subroutine test_automatic_distribution_uniform(this)
      class(ESMF_TestMethod), intent(inout) :: this
      
      type(MeshGeomFactory) :: factory
      type(MeshGeomSpec) :: mesh_spec
      type(MeshDecomposition) :: decomp
      type(ESMF_Geom) :: geom
      type(ESMF_Mesh) :: mesh
      type(ESMF_VM) :: vm
      character(len=:), allocatable :: filename
      integer :: status
      integer :: localPet, petCount
      integer :: local_element_count

      _UNUSED_DUMMY(this)

      ! Get VM info
      call ESMF_VMGetCurrent(vm, rc=status)
      call ESMF_VMGet(vm, localPet=localPet, petCount=petCount, rc=status)
      @assert_that(petCount, is(4))

      ! Create test mesh file with 8 elements
      filename = 'test_auto_dist_uniform.nc'
      if (localPet == 0) then
         call create_eight_element_mesh_file(filename, rc=status)
      end if
      call ESMF_VMBarrier(vm, rc=status)

      ! Create MeshGeomSpec with UNIFORM decomposition
      ! This should trigger the automatic distribution path
      decomp = MeshDecomposition(8, 15, petCount=4)  ! 8 elements, 15 nodes, 4 PEs
      mesh_spec  = MeshGeomSpec(filename, decomposition=decomp, rc=status)
      @assert_that(status, is(0))

      ! Create the ESMF geometry - should use ESMF_MeshCreate automatic path
      geom = factory%make_geom(mesh_spec, rc=status)
      @assert_that(status, is(0))

      ! Verify mesh is correctly distributed
      call ESMF_GeomGet(geom, mesh=mesh, rc=status)
      @assert_that(status, is(0))

      ! Each PE should have 2 elements (8 / 4 = 2)
      call ESMF_MeshGet(mesh, elementCount=local_element_count, rc=status)
      @assert_that(status, is(0))
      @assert_that(local_element_count, is(2))

      ! Cleanup
      call ESMF_VMBarrier(vm, rc=status)
      call ESMF_GeomDestroy(geom, rc=status)
      call ESMF_VMBarrier(vm, rc=status)
      if (localPet == 0) then
         call cleanup_test_file(filename, rc=status)
      end if
      call ESMF_VMBarrier(vm, rc=status)

   end subroutine test_automatic_distribution_uniform


   ! Test custom distribution path (non-uniform decomposition)
   @test(type=ESMF_TestMethod, npes=[4])
   subroutine test_custom_distribution_nonuniform(this)
      class(ESMF_TestMethod), intent(inout) :: this
      
      type(MeshGeomFactory) :: factory
      type(MeshGeomSpec) :: mesh_spec
      type(MeshDecomposition) :: decomp
      type(ESMF_Geom) :: geom
      type(ESMF_Mesh) :: mesh
      type(ESMF_VM) :: vm
      character(len=:), allocatable :: filename
      integer :: status
      integer :: localPet, petCount
      integer :: local_element_count
      integer :: expected_local_elements

      _UNUSED_DUMMY(this)

      ! Get VM info
      call ESMF_VMGetCurrent(vm, rc=status)
      call ESMF_VMGet(vm, localPet=localPet, petCount=petCount, rc=status)
      @assert_that(petCount, is(4))

      ! Create test mesh file with 8 elements
      filename = 'test_custom_dist_nonuniform.nc'
      if (localPet == 0) then
         call create_eight_element_mesh_file(filename, rc=status)
      end if
      call ESMF_VMBarrier(vm, rc=status)

      ! Create MeshGeomSpec with CUSTOM (non-uniform) decomposition
      ! This should trigger the custom distribution path with elementDistgrid
      ! Distribution: PE0=3, PE1=2, PE2=2, PE3=1
      decomp = MeshDecomposition([3, 2, 2, 1], node_distribution=[4, 4, 4, 3])
      mesh_spec  = MeshGeomSpec(filename, decomposition=decomp, rc=status)
      @assert_that(status, is(0))

      ! Create the ESMF geometry - should use ESMF_MeshCreate with custom elementDistgrid
      geom = factory%make_geom(mesh_spec, rc=status)
      @assert_that(status, is(0))

      ! Verify mesh distribution matches custom decomposition
      call ESMF_GeomGet(geom, mesh=mesh, rc=status)
      @assert_that(status, is(0))

      call ESMF_MeshGet(mesh, elementCount=local_element_count, rc=status)
      @assert_that(status, is(0))
      
      ! Verify each PE has the expected custom element count
      select case (localPet)
      case (0)
         expected_local_elements = 3
      case (1)
         expected_local_elements = 2
      case (2)
         expected_local_elements = 2
      case (3)
         expected_local_elements = 1
      end select
      @assert_that(local_element_count, is(expected_local_elements))

      ! Cleanup
      call ESMF_VMBarrier(vm, rc=status)
      call ESMF_GeomDestroy(geom, rc=status)
      call ESMF_VMBarrier(vm, rc=status)
      if (localPet == 0) then
         call cleanup_test_file(filename, rc=status)
      end if
      call ESMF_VMBarrier(vm, rc=status)

   end subroutine test_custom_distribution_nonuniform


   ! Test automatic distribution with remainder (10 elements on 4 PEs)
   @test(type=ESMF_TestMethod, npes=[4])
   subroutine test_automatic_distribution_with_remainder(this)
      class(ESMF_TestMethod), intent(inout) :: this
      
      type(MeshGeomFactory) :: factory
      type(MeshGeomSpec) :: mesh_spec
      type(MeshDecomposition) :: decomp
      type(ESMF_Geom) :: geom
      type(ESMF_Mesh) :: mesh
      type(ESMF_VM) :: vm
      character(len=:), allocatable :: filename
      integer :: status
      integer :: localPet, petCount
      integer :: local_element_count
      integer :: expected_local_elements

      _UNUSED_DUMMY(this)

      ! Get VM info
      call ESMF_VMGetCurrent(vm, rc=status)
      call ESMF_VMGet(vm, localPet=localPet, petCount=petCount, rc=status)
      @assert_that(petCount, is(4))

      ! Create test mesh file with 10 elements
      ! 10 / 4 = 2 remainder 2
      ! Expected: PE0=3, PE1=3, PE2=2, PE3=2
      filename = 'test_auto_dist_remainder.nc'
      if (localPet == 0) then
         call create_ten_element_mesh_file(filename, rc=status)
      end if
      call ESMF_VMBarrier(vm, rc=status)

      ! Create MeshGeomSpec with uniform decomposition
      decomp = MeshDecomposition(10, 18, petCount=4)  ! 10 elements, 18 nodes, 4 PEs
      mesh_spec  = MeshGeomSpec(filename, decomposition=decomp, rc=status)
      @assert_that(status, is(0))

      ! Create the ESMF geometry
      geom = factory%make_geom(mesh_spec, rc=status)
      @assert_that(status, is(0))

      ! Verify distribution
      call ESMF_GeomGet(geom, mesh=mesh, rc=status)
      @assert_that(status, is(0))

      call ESMF_MeshGet(mesh, elementCount=local_element_count, rc=status)
      @assert_that(status, is(0))
      
      ! First 2 PEs get 3 elements, last 2 PEs get 2 elements
      select case (localPet)
      case (0)
         expected_local_elements = 3
      case (1)
         expected_local_elements = 3
      case (2)
         expected_local_elements = 2
      case (3)
         expected_local_elements = 2
      end select
      @assert_that(local_element_count, is(expected_local_elements))

      ! Cleanup
      call ESMF_VMBarrier(vm, rc=status)
      call ESMF_GeomDestroy(geom, rc=status)
      call ESMF_VMBarrier(vm, rc=status)
      if (localPet == 0) then
         call cleanup_test_file(filename, rc=status)
      end if
      call ESMF_VMBarrier(vm, rc=status)

   end subroutine test_automatic_distribution_with_remainder


   ! Test single PE case (should use automatic path)
   @test(type=ESMF_TestMethod, npes=[1])
   subroutine test_single_pe_automatic_distribution(this)
      class(ESMF_TestMethod), intent(inout) :: this
      
      type(MeshGeomFactory) :: factory
      type(MeshGeomSpec) :: mesh_spec
      type(MeshDecomposition) :: decomp
      type(ESMF_Geom) :: geom
      type(ESMF_Mesh) :: mesh
      character(len=:), allocatable :: filename
      integer :: status
      integer :: nodeCount, elementCount

      _UNUSED_DUMMY(this)

      ! Create test mesh file
      filename = 'test_single_pe_auto.nc'
      call create_simple_quad_file(filename, rc=status)

      ! Create MeshGeomSpec with single-PE decomposition
      decomp = MeshDecomposition([1])
      mesh_spec  = MeshGeomSpec(filename, decomposition=decomp, rc=status)
      @assert_that(status, is(0))

      ! Create the ESMF geometry - should use automatic path
      geom = factory%make_geom(mesh_spec, rc=status)
      @assert_that(status, is(0))

      ! Verify mesh
      call ESMF_GeomGet(geom, mesh=mesh, rc=status)
      @assert_that(status, is(0))

      call ESMF_MeshGet(mesh, nodeCount=nodeCount, elementCount=elementCount, rc=status)
      @assert_that(status, is(0))
      @assert_that(nodeCount, is(4))
      @assert_that(elementCount, is(1))

      ! Cleanup
      call ESMF_GeomDestroy(geom, rc=status)
      call cleanup_test_file(filename, rc=status)

   end subroutine test_single_pe_automatic_distribution


   !===========================================================================
   ! Helper subroutine to create 10-element mesh file for remainder test
   !===========================================================================
   subroutine create_ten_element_mesh_file(filename, rc)
      use pfio
      use mapl_ErrorHandlingMod
      use, intrinsic :: iso_fortran_env, only: REAL64, INT32
      
      character(len=*), intent(in) :: filename
      integer, optional, intent(out) :: rc

      integer :: status
      type(FileMetadata) :: file_metadata
      type(NetCDF4_FileFormatter) :: formatter
      type(Variable) :: var
      
      ! 10 quads in a 2x5 grid
      integer, parameter :: n_nodes = 18  ! 3x6 node grid
      integer, parameter :: n_elements = 10
      integer, parameter :: n_conn = 40   ! 10 quads * 4 nodes each
      
      real(kind=REAL64) :: node_coords(2, n_nodes)
      integer(kind=INT32) :: element_conn(n_conn)
      integer(kind=INT32) :: num_element_conn(n_elements)
      integer :: i, j, node_idx, elem_idx, conn_idx

      ! Create 3x6 node grid
      node_idx = 1
      do j = 1, 6
         do i = 1, 3
            node_coords(1, node_idx) = real(i-1, REAL64)  ! lon: 0, 1, 2
            node_coords(2, node_idx) = real(j-1, REAL64)  ! lat: 0, 1, 2, 3, 4, 5
            node_idx = node_idx + 1
         end do
      end do

      ! Create 2x5 = 10 quad elements
      conn_idx = 1
      elem_idx = 1
      do j = 1, 5
         do i = 1, 2
            ! Quad connecting nodes in counter-clockwise order
            element_conn(conn_idx) = (j-1)*3 + i
            element_conn(conn_idx+1) = (j-1)*3 + i + 1
            element_conn(conn_idx+2) = j*3 + i + 1
            element_conn(conn_idx+3) = j*3 + i
            
            num_element_conn(elem_idx) = 4
            
            conn_idx = conn_idx + 4
            elem_idx = elem_idx + 1
         end do
      end do

      ! Create file metadata
      file_metadata = FileMetadata()
      
      call file_metadata%add_dimension('nodeCount', n_nodes, rc=status)
      call file_metadata%add_dimension('elementCount', n_elements, rc=status)
      call file_metadata%add_dimension('coordDim', 2, rc=status)
      call file_metadata%add_dimension('connectionCount', n_conn, rc=status)

      var = Variable(type=pFIO_REAL64, dimensions='coordDim,nodeCount', rc=status)
      call var%add_attribute('units', Attribute('degrees'))
      call file_metadata%add_variable('nodeCoords', var, rc=status)

      var = Variable(type=pFIO_INT32, dimensions='connectionCount', rc=status)
      call file_metadata%add_variable('elementConn', var, rc=status)

      var = Variable(type=pFIO_INT32, dimensions='elementCount', rc=status)
      call file_metadata%add_variable('numElementConn', var, rc=status)

      call file_metadata%add_attribute('gridType', Attribute('unstructured'))
      call file_metadata%add_attribute('version', Attribute('0.9'))
      call file_metadata%add_attribute('convention', Attribute('ESMF'))

      ! Write file
      call formatter%create(file=filename, mode=pFIO_CLOBBER, rc=status)
      call formatter%write(file_metadata, rc=status)
      call formatter%put_var('nodeCoords', node_coords, rc=status)
      call formatter%put_var('elementConn', element_conn, rc=status)
      call formatter%put_var('numElementConn', num_element_conn, rc=status)
      call formatter%close(rc=status)

      if (present(rc)) rc = 0
   end subroutine create_ten_element_mesh_file

end module Test_MeshGeomFactory_Distribution
