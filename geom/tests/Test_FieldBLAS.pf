!
!      grid = ESMF_GridCreateNoPeriDim(minIndex=[1, 1], maxIndex=[4,4], name='r4_grid', rc=status)
!      write(*, '(a)') PROC_NAME // ': RC = ' // rc_to_string(status)
!      PRINT_RC(status)
!      _ASSERT(SUCCESS(status), MSG('Failed to create grid'))
!      field = ESMF_FieldCreate(grid, typekind=ESMF_TYPEKIND_R4, name='r4_field', rc=status)
!      PRINT_RC(status)
!      _ASSERT(SUCCESS(status), MSG('Failed to create field'))
!      _RETURN(_SUCCESS)
!
!   end function mk_field_r4

   function mk_field_r8(array_ptr, regDecomp, maxIndex, indexflag, name, rc) result(field)
      character(len=*), parameter :: PROC_NAME = 'MK_FIELD_R8'
      character(len=*), parameter :: GRID_SUFFIX = '_grid'
      character(len=*), parameter :: FIELD_SUFFIX = '_field'
      real(kind=ESMF_KIND_R8), dimension(:,:), pointer, intent(in) :: array_ptr
      integer, dimension(:), intent(in) :: regDecomp
      integer, dimension(:), intent(in) :: maxIndex
      type(ESMF_Index_Flag), intent(in) :: indexflag
      character(len=*), intent(in) :: name
      integer, optional, intent(out) :: rc

      type(ESMF_Field) :: field
      type(ESMF_Grid) :: grid

      integer :: status

      grid = mk_grid(regDecomp=regDecomp, maxIndex=maxIndex, indexflag=indexflag, grid_name = name // GRID_SUFFIX, rc = status)
      field = ESMF_FieldCreate(grid, farrayPtr = array_ptr, name = name // FIELD_SUFFIX, rc = status)
      PRINT_RC(status)
      _ASSERT(SUCCESS(status), MSG('Failed to create field'))
      _RETURN(_SUCCESS)

   end function mk_field_r8

   @Before
   subroutine set_up_data()
      implicit none

      integer :: status, rc

      real(kind=ESMF_KIND_R4), parameter :: ADD_R4 = 100.0
      real(kind=ESMF_KIND_R8), parameter :: ADD_R8 = 100.0
!      real(kind=ESMF_KIND_R4), dimension(:,:), pointer :: x4_array_ptr 
!      real(kind=ESMF_KIND_R8), dimension(:,:), pointer :: x8_array_ptr 
!      real(kind=ESMF_KIND_R4), dimension(:,:), pointer :: y4_array_ptr 
!      real(kind=ESMF_KIND_R8), dimension(:,:), pointer :: y8_array_ptr 

!      allocate(x4_array_ptr, source=R4_ARRAY_DEFAULT)
!      allocate(x8_array_ptr, source=R8_ARRAY_DEFAULT)!wdb  fixme 
!      allocate(y4_array_ptr, source=R4_ARRAY_DEFAULT)
!      allocate(y8_array_ptr, source=R8_ARRAY_DEFAULT)!wdb  fixme

!      y4_array_ptr = y4_array_ptr + ADD_R4!wdb  fixme
!      y8_array_ptr = y8_array_ptr + ADD_R8!wdb  fixme

      XR4 = mk_field(R4_ARRAY_DEFAULT, regDecomp=REG_DECOMP_DEFAULT, minIndex=MIN_INDEX_DEFAULT, maxIndex=MAX_INDEX_DEFAULT,
         indexflag=INDEX_FLAG_DEFAULT, name = 'XR4', rc = status)
!      XR4 = mk_field(x4_array_ptr, REG_DECOMP_DEFAULT, MAX_INDEX_DEFAULT, INDEX_FLAG_DEFAULT, name = 'XR4', rc = status)
!      XR8 = mk_field(x8_array_ptr, REG_DECOMP_DEFAULT, MAX_INDEX_DEFAULT, INDEX_FLAG_DEFAULT, rc = status)!wdb  fixme
!      YR4 = mk_field(y4_array_ptr, REG_DECOMP_DEFAULT, MAX_INDEX_DEFAULT, INDEX_FLAG_DEFAULT, name = 'YR4', rc = status)
!      YR8 = mk_field(y8_array_ptr, REG_DECOMP_DEFAULT, MAX_INDEX_DEFAULT, INDEX_FLAG_DEFAULT, rc = status)!wdb  fixme

   end subroutine set_up_data

!   @Test
   ! Basic test of FieldCOPY subroutine (REAL32)
   subroutine test_FieldCOPY_R4()
      character(len=*), parameter :: PROC_NAME = 'test_FieldCOPY_R4'
      type(ESMF_Field) :: x
      type(ESMF_Field) :: y
      real(kind=ESMF_KIND_R4), dimension(:,:), pointer :: x_ptr
      real(kind=ESMF_KIND_R4), dimension(:,:), pointer :: y_ptr
      integer :: status, rc
      
      write(*,*) 'Running test_' // 'FieldCopy_R4'

      x = XR4
      y = YR4

      call FieldCOPY(x, y, rc = status)
      _ASSERT(SUCCESS(status), MSG('Copy failed'))
      
      call ESMF_FieldGet(x, farrayPtr = x_ptr, rc = status)
      _ASSERT(SUCCESS(status), MSG('Failed to get source data pointer'))

      call ESMF_FieldGet(y, farrayPtr = y_ptr, rc = status)
      _ASSERT(SUCCESS(status), MSG('Failed to get destination data pointer'))

      @assertEqual(x_ptr, y_ptr)

   end subroutine test_FieldCOPY_R4

!   @Test
   ! Basic test of FieldCOPY subroutine (REAL64)
   subroutine test_FieldCOPY_R8()
      character(len=*), parameter :: PROC_NAME = 'test_FieldCOPY_R8'
      type(ESMF_Field) :: x
      type(ESMF_Field) :: y
      real(kind=ESMF_KIND_R8), dimension(:,:), pointer :: x_ptr
      real(kind=ESMF_KIND_R8), dimension(:,:), pointer :: y_ptr
      integer :: status, rc
      
      write(*,*) 'Running test_' // 'FieldCopy_R8'

      x = XR8 
      y = YR8

      call FieldCOPY(x, y, rc = status)
      _ASSERT(SUCCESS(status), MSG('Copy failed'))
      
      call ESMF_FieldGet(x, farrayPtr = x_ptr, rc = status)
      _ASSERT(SUCCESS(status), MSG('Failed to get source data pointer'))

      call ESMF_FieldGet(y, farrayPtr = y_ptr, rc = status)
      _ASSERT(SUCCESS(status), MSG('Failed to get destination data pointer'))

      @assertEqual(x_ptr, y_ptr)

   end subroutine test_FieldCOPY_R8

!   @Test
   ! Basic test of FieldSCAL subroutine (REAL32)
   subroutine test_FieldSCAL_R4()
      character(len=*), parameter :: PROC_NAME = 'test_FieldSCAL_R4'
      real(kind=ESMF_KIND_R4), parameter :: a = 2.0
      type(ESMF_Field) :: x
      real(kind=ESMF_KIND_R4), dimension(:,:), pointer :: x_ptr
      integer :: status, rc

      write(*,*) 'Running test_' // 'FieldSCAL_R4'

      x = XR4

      call FieldSCAL(a, x, rc = status)
      _ASSERT(SUCCESS(status), MSG('Scale failed'))   

      call ESMF_FieldGet(x, farrayPtr = x_ptr, rc = status)
      _ASSERT(SUCCESS(status), MSG('Failed to get data pointer'))

      @assertEqual(x_ptr, a*R4_ARRAY_DEFAULT)

   end subroutine test_FieldSCAL_R4

!   @Test
   ! Basic test of FieldSCAL subroutine (REAL64)
   subroutine test_FieldSCAL_R8()
      character(len=*), parameter :: PROC_NAME = 'test_FieldSCAL_R8'
      real(kind=ESMF_KIND_R8), parameter :: a = 2.0
      type(ESMF_Field) :: x
      real(kind=ESMF_KIND_R8), dimension(:,:), pointer :: x_ptr
      integer :: status, rc

      write(*,*) 'Running test_' // 'FieldSCAL_R8'

      x = XR8

      call FieldSCAL(a, x, rc = status)
      _ASSERT(SUCCESS(status), MSG('Scale failed'))
      
      call ESMF_FieldGet(x, farrayPtr = x_ptr, rc = status)
      _ASSERT(SUCCESS(status), MSG('Failed to get data pointer'))

      @assertEqual(x_ptr, a*R8_ARRAY_DEFAULT)

   end subroutine test_FieldSCAL_R8

!   @Test
   !
   subroutine test_FieldAXPY_R4()
      character(len=*), parameter :: PROC_NAME = 'test_FieldAXPY_R4'
      real(kind=ESMF_KIND_R4), parameter :: a = 2.0
      type(ESMF_Field) :: x
      type(ESMF_Field) :: y
      real(kind=ESMF_KIND_R4), dimension(:,:), allocatable :: x_array
      real(kind=ESMF_KIND_R4), dimension(:,:), pointer :: x_ptr
      real(kind=ESMF_KIND_R4), dimension(:,:), allocatable :: y_array
      real(kind=ESMF_KIND_R4), dimension(:,:), pointer :: y_ptr
      integer :: status, rc

      x = XR4
      y = YR4

      call ESMF_FieldGet(x, farrayPtr = x_ptr, rc = status)
      _ASSERT(status == ESMF_SUCCESS, MSG('Failed to get initial x_ptr'))
      x_array = x_ptr

      call ESMF_FieldGet(y, farrayPtr = y_ptr, rc = status)
      _ASSERT(status == ESMF_SUCCESS, MSG('Failed to get initial y_ptr'))
      y_array = y_ptr

      call FieldAXPY(a, x, y, rc = status)
      _ASSERT(status == ESMF_SUCCESS, MSG('Failed affine transformation'))
      
      call ESMF_FieldGet(x, farrayPtr = x_ptr, rc = status)
      _ASSERT(status == ESMF_SUCCESS, MSG('Failed to get final x_ptr'))

      call ESMF_FieldGet(y, farrayPtr = y_ptr, rc = status)
      _ASSERT(status == ESMF_SUCCESS, MSG('Failed to get final y_ptr'))

      @assertEqual(y_ptr, a*x_array+y_array)

   end subroutine test_FieldAXPY_R4

!   @Test
   !
   subroutine test_FieldAXPY_R8()
      character(len=*), parameter :: PROC_NAME = 'test_FieldAXPY_R8'
      real(kind=ESMF_KIND_R8), parameter :: a = 2.0
      type(ESMF_Field) :: x
      type(ESMF_Field) :: y
      real(kind=ESMF_KIND_R8), dimension(:,:), allocatable :: x_array
      real(kind=ESMF_KIND_R8), dimension(:,:), pointer :: x_ptr
      real(kind=ESMF_KIND_R8), dimension(:,:), allocatable :: y_array
      real(kind=ESMF_KIND_R8), dimension(:,:), pointer :: y_ptr
      integer :: status, rc

      x = XR8
      y = YR8

      call ESMF_FieldGet(x, farrayPtr = x_ptr, rc = status)
      _ASSERT(status == ESMF_SUCCESS, MSG('Failed to get initial x_ptr'))
      x_array = x_ptr

      call ESMF_FieldGet(y, farrayPtr = y_ptr, rc = status)
      _ASSERT(status == ESMF_SUCCESS, MSG('Failed to get initial y_ptr'))
      y_array = y_ptr

      call FieldAXPY(a, x, y, rc = status)
      _ASSERT(status == ESMF_SUCCESS, MSG('Failed affine transformation'))
      
      call ESMF_FieldGet(x, farrayPtr = x_ptr, rc = status)
      _ASSERT(status == ESMF_SUCCESS, MSG('Failed to get final x_ptr'))

      call ESMF_FieldGet(y, farrayPtr = y_ptr, rc = status)
      _ASSERT(status == ESMF_SUCCESS, MSG('Failed to get final y_ptr'))

      @assertEqual(y_ptr, a*x_array+y_array)

   end subroutine test_FieldAXPY_R8

