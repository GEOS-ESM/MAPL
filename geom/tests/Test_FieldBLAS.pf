   elemental function are_almost_equal(x, y) result(almost_equal)
      real(kind=ESMF_KIND_R4), parameter :: EPS = epsilon(real(1.0, kind=ESMF_KIND_R4))
      real(kind=ESMF_KIND_R8), intent(in) :: x
      real(kind=ESMF_KIND_R4), intent(in) :: y
      logical :: almost_equal

      if(y==0) then
         almost_equal = (x==0)
      else
         almost_equal = (abs(x-y)/abs(y) < EPS)
      end if

   end function are_almost_equal

   @Test
   subroutine test_almost_equal_scalar()
      character(len=*), parameter :: MSG = 'Difference exceeds threshold'
      real(kind=ESMF_KIND_R8), parameter :: X = 1.0 / 3.0
      real(kind=ESMF_KIND_R4) :: y

      y = X
      @assertTrue(are_almost_equal(X, y), trim(MSG))
      
   end subroutine test_almost_equal_scalar
      
   @Test
   subroutine test_almost_equal_array()
      integer, parameter :: N = 3
      character(len=*), parameter :: MSG = 'Difference exceeds threshold'
      real(kind=ESMF_KIND_R8), parameter :: DENOMS(N) = [3.0, 5.0, 7.0]
      real(kind=ESMF_KIND_R8), parameter :: X(N) = 1.0 / DENOMS
      real(kind=ESMF_KIND_R4) :: y(N)

      y = X

      @assertTrue(all(are_almost_equal(x, y)), trim(MSG))

   end subroutine test_almost_equal_array

   subroutine write_r4_array_2d(X)
      real(kind=ESMF_KIND_R4), intent(in) :: X(:,:)
      integer :: i

      do i = 1, size(X, 1)
         call write_array(X(i, :))
      end do
      write(*,*)

   end subroutine write_r4_array_2d

   subroutine write_r4_array_1d(v)
      character(len=*), parameter :: FMT = '(E0.8,1X)'
      real(kind=ESMF_KIND_R4), intent(in) :: v(:)
      integer :: i
      do i = 1,size(v)
         write(*, fmt=FMT, advance='NO') v(i)
      end do
      write(*, *)
   end subroutine write_r4_array_1d

   subroutine write_r4_array_ptr_2d(X)
      real(kind=ESMF_KIND_R4), pointer, intent(in) :: X(:,:)
      integer :: i

      do i = 1, size(X, 1)
         call write_array(X(i, :))
      end do
      write(*,*)

   end subroutine write_r4_array_ptr_2d

   subroutine write_r4_array_ptr_1d(v)
      character(len=*), parameter :: FMT = '(E0.8,1X)'
      real(kind=ESMF_KIND_R4), pointer, intent(in) :: v(:)
      integer :: i
      do i = 1,size(v)
         write(*, fmt=FMT, advance='NO') v(i)
      end do
      write(*, *)
   end subroutine write_r4_array_ptr_1d
   
   subroutine write_r8_array_2d(X)
      real(kind=ESMF_KIND_R8), intent(in) :: X(:,:)
      integer :: i

      do i = 1, size(X, 1)
         call write_array(X(i, :))
      end do
      write(*,*)

   end subroutine write_r8_array_2d

   subroutine write_r8_array_1d(v)
      character(len=*), parameter :: FMT = '(E0.16,1X)'
      real(kind=ESMF_KIND_R8), intent(in) :: v(:)
      integer :: i
      do i = 1,size(v)
         write(*, fmt=FMT, advance='NO') v(i)
      end do
      write(*, *)
   end subroutine write_r8_array_1d

end module Test_FieldBLAS
