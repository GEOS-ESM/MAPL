   function mk_field_simple_r4(farray, rc) result(field)
      real(kind=ESMF_KIND_R4), dimension(:,:),  intent(in) :: farray
      integer, optional, intent(out) :: rc
      type(ESMF_Field) :: field
      type(ESMF_TypeKind_Flag), parameter :: tk = ESMF_TYPEKIND_R4
      real(kind=ESMF_KIND_R4), dimension(:,:), pointer :: fptr
      type(ESMF_Grid) :: grid
      integer :: status

      allocate(fptr(4,4))
      write(*,fmt='(a,i2,a,i2,a)') 'fptr dimensions: [', size(fptr, 1), ', ', size(fptr, 2), ']'

      grid = mk_grid(_RC)
      if(status == ESMF_SUCCESS) field = ESMF_FieldCreate(grid, tk, _RC)
      if(status == ESMF_SUCCESS) call ESMF_FieldGet(field, farrayPtr = fptr, _RC)
      if(status == ESMF_SUCCESS) fptr = farray
      if(present(rc)) rc = status

   end function mk_field_simple_r4

end module Test_FieldBLAS
