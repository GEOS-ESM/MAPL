#include "MAPL_Generic.h"

module Test_FieldBLAS

   use mapl3g_FieldBLAS
   use ESMF
   use funit
   use MAPL_ExceptionHandling
!   use, intrinsic :: iso_fortran_env, only: R4 => REAL32, R8 => REAL64
!   use ESMF, only: R4 => ESMF_KIND_R4, R8 => ESMF_KIND_R8

   implicit none

   interface mk_field
      module procedure mk_field_r4
      module procedure mk_field_r8
   end interface mk_field

   integer :: i
   integer, dimension(*), parameter :: DIM_DEFAULT = [4, 4]
   integer, dimension(*), parameter :: REG_DECOMP_DEFAULT = [4, 4]
   integer, dimension(*), parameter :: MAX_INDEX_DEFAULT = [4, 4]
   integer, dimension(*), parameter :: DIMR4_DEFAULT = [4, 4]
   integer, dimension(*), parameter :: DIMR8_DEFAULT = [4, 4]
   integer, parameter :: SIZE_R4 = 16
   integer, parameter :: SIZE_R8 = 16
   real(kind=ESMF_KIND_R4), dimension(*,*), parameter :: R4_ARRAY_DEFAULT = &
      & reshape([(i, i = 1, SIZE_R4)], DIMR4_DEFAULT)
!      & reshape([( ((i+DIMR4_DEFAULT*(j-1)), i = 1, DIMR4_DEFAULT(2)  ), j = 1, DIMR4_DEFAULT(1) )], DIMR4_DEFAULT)
   real(kind=ESMF_KIND_R8), dimension(*,*), parameter :: R8_ARRAY_DEFAULT = R4_ARRAY_DEFAULT
   type(ESMF_Index_Flag), parameter :: INDEX_FLAG_DEFAULT = ESMF_INDEX_DELOCAL

contains

   function mk_grid(reg_dc, max_idx, rc) result(grid)
      integer, dimension(:), optional, intent(in) :: reg_dc
      integer, dimension(:), optional, intent(in) :: max_idx
      integer, optional, intent(out) :: rc
      type(ESMF_Grid) :: grid
      integer, dimension(:), allocatable :: actual_reg_dc
      integer, dimension(:), allocatable :: actual_max_idx
      integer :: status
      
      actual_reg_dc = REG_DECOMP_DEFAULT
      if(present(reg_dc)) actual_reg_dc = reg_dc

      actual_max_idx = MAX_INDEX_DEFAULT
      if(present(max_idx)) actual_max_idx = max_idx

      grid = ESMF_GridCreateNoPeriDim(regDecomp = actual_reg_dc, &
         & maxIndex = actual_max_idx, rc = status)

      if(present(rc)) rc = status

   end function mk_grid
   
   function mk_field_r4(farray, index_flag, reg_dc, max_idx, rc) result(field)
      real(kind=ESMF_KIND_R4), dimension(:,:),  intent(in) :: farray
      type(ESMF_Index_Flag), optional, intent(in) :: index_flag
      integer, dimension(:), optional, intent(in) :: reg_dc
      integer, dimension(:), optional, intent(in) :: max_idx
      integer, optional, intent(out) :: rc
      type(ESMF_Field) :: field
      type(ESMF_Grid) :: grid
      type(ESMF_Index_Flag) :: actual_index_flag
      integer, dimension(:), allocatable :: actual_reg_dc
      integer, dimension(:), allocatable :: actual_max_idx
      integer :: status

      actual_index_flag = INDEX_FLAG_DEFAULT
      if(present(index_flag)) actual_index_flag = index_flag

      actual_reg_dc = shape(farray)
      if(present(reg_dc)) actual_reg_dc = reg_dc
  
      actual_max_idx = actual_reg_dc
      if(present(max_idx)) actual_max_idx = max_idx

      grid = mk_grid(actual_reg_dc, actual_max_idx, _RC)
      if(status == ESMF_SUCCESS) field = ESMF_FieldCreate(grid, farray, actual_index_flag, _RC)
      if(present(rc)) rc = status

   end function mk_field_r4

   function mk_field_r8(farray, index_flag, reg_dc, max_idx, rc) result(field)
      real(kind=ESMF_KIND_R8), dimension(:,:),  intent(in) :: farray
      type(ESMF_Index_Flag), optional, intent(in) :: index_flag
      integer, dimension(:), optional, intent(in) :: reg_dc
      integer, dimension(:), optional, intent(in) :: max_idx
      integer, optional, intent(out) :: rc
      type(ESMF_Field) :: field
      type(ESMF_Grid) :: grid
      type(ESMF_Index_Flag) :: actual_index_flag
      integer, dimension(:), allocatable :: actual_reg_dc
      integer, dimension(:), allocatable :: actual_max_idx
      integer :: status

      actual_index_flag = INDEX_FLAG_DEFAULT
      if(present(index_flag)) actual_index_flag = index_flag

      actual_reg_dc = shape(farray)
      if(present(reg_dc)) actual_reg_dc = reg_dc
  
      actual_max_idx = actual_reg_dc
      if(present(max_idx)) actual_max_idx = max_idx

      grid = mk_grid(actual_reg_dc, actual_max_idx, _RC)
      if(status == ESMF_SUCCESS) field = ESMF_FieldCreate(grid, farray, actual_index_flag, _RC)
      if(present(rc)) rc = status

   end function mk_field_r8

!   function mk_field_r8(farray, index_flag, reg_dc, max_idx, rc) result(field)
!      real(kind=ESMF_KIND_R8), dimension(:,:),  intent(in) :: farray
!      type(ESMF_Index_Flag), optional, intent(in) :: index_flag
!      integer, dimension(:), optional, intent(in) :: reg_dc
!      integer, dimension(:), optional, intent(in) :: max_idx
!      integer, optional, intent(out) :: rc
!      type(ESMF_Field) :: field
!      type(ESMF_Grid) :: grid
!      type(ESMF_Index_Flag) :: actual_index_flag
!      integer :: status
!
!      actual_index_flag = INDEX_FLAG_DEFAULT
!      if(present(index_flag)) actual_index_flag = index_flag
!
!      grid = mk_grid(reg_dc, max_idx, _RC)
!      if(status == ESMF_SUCCESS) field = ESMF_FieldCreate(grid, farray, actual_index_flag, _RC)
!      if(present(rc)) rc = status
!
!   end function mk_field_r8

   @test
   ! Basic test of FieldCOPY subroutine (REAL32)
   subroutine test_FieldCOPY_R4()
      type(ESMF_Field) :: x
      type(ESMF_Field) :: y
      real(kind=ESMF_KIND_R4), dimension(:,:), allocatable :: x_array
      real(kind=ESMF_KIND_R4), dimension(:,:), pointer :: x_ptr
      real(kind=ESMF_KIND_R4), dimension(:,:), allocatable :: y_array
      real(kind=ESMF_KIND_R4), dimension(:,:), pointer :: y_ptr
      integer :: status
      
      allocate(x_array, source=R4_ARRAY_DEFAULT)
      allocate(y_array, source=x_array)
      y_array = y_array + 100

      do while(.TRUE.)
!         x = mk_field(x_array, rc = status)
         x = mk_field_simple_r4(x_array, rc = status)
         if(status /= ESMF_SUCCESS) exit

         y  = mk_field(y_array, rc = status)
         if(status /= ESMF_SUCCESS) exit

         call FieldCOPY(x, y, rc = status)
         if(status /= ESMF_SUCCESS) exit
         
         call ESMF_FieldGet(x, farrayPtr = x_ptr, rc = status)
         if(status /= ESMF_SUCCESS) exit

         call ESMF_FieldGet(y, farrayPtr = y_ptr, rc = status)
         if(status /= ESMF_SUCCESS) exit

         @assertEqual(x_ptr, y_ptr)
         exit
      end do

   end subroutine test_FieldCOPY_R4

   @test
   ! Basic test of FieldCOPY subroutine (REAL64)
   subroutine test_FieldCOPY_R8()
      type(ESMF_Field) :: x
      type(ESMF_Field) :: y
      real(kind=ESMF_KIND_R8), dimension(:,:), allocatable :: x_array
      real(kind=ESMF_KIND_R8), dimension(:,:), pointer :: x_ptr
      real(kind=ESMF_KIND_R8), dimension(:,:), allocatable :: y_array
      real(kind=ESMF_KIND_R8), dimension(:,:), pointer :: y_ptr
      integer :: status
      
      allocate(x_array, source=R8_ARRAY_DEFAULT)
      allocate(y_array, source=x_array)
      y_array = y_array + 100

      do while(.TRUE.)
         x = mk_field(x_array, rc = status)
         if(status /= ESMF_SUCCESS) exit

         y  = mk_field(y_array, rc = status)
         if(status /= ESMF_SUCCESS) exit

         call FieldCOPY(x, y, rc = status)
         if(status /= ESMF_SUCCESS) exit
         
         call ESMF_FieldGet(x, farrayPtr = x_ptr, rc = status)
         if(status /= ESMF_SUCCESS) exit

         call ESMF_FieldGet(y, farrayPtr = y_ptr, rc = status)
         if(status /= ESMF_SUCCESS) exit

         @assertEqual(x_ptr, y_ptr)
         exit
      end do

   end subroutine test_FieldCOPY_R8

   @test
   ! Basic test of FieldSCAL subroutine (REAL32)
   subroutine test_FieldSCAL_R4()
      real(kind=ESMF_KIND_R4), parameter :: a = 2.0
      type(ESMF_Field) :: x
      real(kind=ESMF_KIND_R4), dimension(:,:), allocatable :: x_array
      real(kind=ESMF_KIND_R4), dimension(:,:), pointer :: x_ptr
      integer :: status

      allocate(x_array, source = R4_ARRAY_DEFAULT)

      do while(.TRUE.)
         x = mk_field(x_array, rc = status)
         if(status /= ESMF_SUCCESS) exit

         call FieldSCAL(a, x, rc = status)
         if(status /= ESMF_SUCCESS) exit
         
         call ESMF_FieldGet(x, farrayPtr = x_ptr, rc = status)
         if(status /= ESMF_SUCCESS) exit

         @assertEqual(x_ptr, a*x_array)
         exit
      end do
   end subroutine test_FieldSCAL_R4

   @test
   ! Basic test of FieldSCAL subroutine (REAL64)
   subroutine test_FieldSCAL_R8()
      real(kind=ESMF_KIND_R8), parameter :: a = 2.0
      type(ESMF_Field) :: x
      real(kind=ESMF_KIND_R8), dimension(:,:), allocatable :: x_array
      real(kind=ESMF_KIND_R8), dimension(:,:), pointer :: x_ptr
      integer :: status

      allocate(x_array, source = R8_ARRAY_DEFAULT)

      do while(.TRUE.)
         x = mk_field(x_array, rc = status)
         if(status /= ESMF_SUCCESS) exit

         call FieldSCAL(a, x, rc = status)
         if(status /= ESMF_SUCCESS) exit
         
         call ESMF_FieldGet(x, farrayPtr = x_ptr, rc = status)
         if(status /= ESMF_SUCCESS) exit

         @assertEqual(x_ptr, a*x_array)
         exit
      end do
   end subroutine test_FieldSCAL_R8

!   @test
   !
   subroutine test_FieldAXPY_R4()
      real(kind=ESMF_KIND_R4), parameter :: a = 2.0
      type(ESMF_Field) :: x
      type(ESMF_Field) :: y
      real(kind=ESMF_KIND_R4), dimension(:,:), allocatable :: x_array
      real(kind=ESMF_KIND_R4), dimension(:,:), pointer :: x_ptr
      real(kind=ESMF_KIND_R4), dimension(:,:), allocatable :: y_array
      real(kind=ESMF_KIND_R4), dimension(:,:), pointer :: y_ptr
      integer :: status

      allocate(x_array, source = R4_ARRAY_DEFAULT)
      allocate(y_array, source = R4_ARRAY_DEFAULT)
      y_array = y_array + 100

      do while(.TRUE.)
         x = mk_field(x_array, rc = status)
         if(status /= ESMF_SUCCESS) exit

         y = mk_field(y_array, rc = status)
         if(status /= ESMF_SUCCESS) exit

         call FieldAXPY(a, x, y, rc = status)
         if(status /= ESMF_SUCCESS) exit
         
         call ESMF_FieldGet(x, farrayPtr = x_ptr, rc = status)
         if(status /= ESMF_SUCCESS) exit

         call ESMF_FieldGet(y, farrayPtr = y_ptr, rc = status)
         if(status /= ESMF_SUCCESS) exit

         @assertEqual(y_ptr, a*x_array+y_array)
         exit
      end do
   end subroutine test_FieldAXPY_R4

!   @test
   !
   subroutine test_FieldAXPY_R8()
      real(kind=ESMF_KIND_R8), parameter :: a = 2.0
      type(ESMF_Field) :: x
      type(ESMF_Field) :: y
      real(kind=ESMF_KIND_R8), dimension(:,:), allocatable :: x_array
      real(kind=ESMF_KIND_R8), dimension(:,:), pointer :: x_ptr
      real(kind=ESMF_KIND_R8), dimension(:,:), allocatable :: y_array
      real(kind=ESMF_KIND_R8), dimension(:,:), pointer :: y_ptr
      integer :: status

      allocate(x_array, source = R8_ARRAY_DEFAULT)
      allocate(y_array, source = R8_ARRAY_DEFAULT)
      y_array = y_array + 100

      do while(.TRUE.)
         x = mk_field(x_array, rc = status)
         if(status /= ESMF_SUCCESS) exit

         y = mk_field(y_array, rc = status)
         if(status /= ESMF_SUCCESS) exit

         call FieldAXPY(a, x, y, rc = status)
         if(status /= ESMF_SUCCESS) exit
         
         call ESMF_FieldGet(x, farrayPtr = x_ptr, rc = status)
         if(status /= ESMF_SUCCESS) exit

         call ESMF_FieldGet(y, farrayPtr = y_ptr, rc = status)
         if(status /= ESMF_SUCCESS) exit

         @assertEqual(y_ptr, a*x_array+y_array)
         exit
      end do
   end subroutine test_FieldAXPY_R8

