   subroutine test_FieldsAreConformable()
      character(len=*), parameter :: PROC_NAME = 'test_FieldsAreConformable'
      type(ESMF_Field) :: x
      logical are_conformable
      integer :: status, rc

      are_conformable = .FALSE.
      x = XR4
      @assertTrue(FieldsAreConformable(x, x, rc = status))
      _ASSERT(SUCCESS(status), MSG('Call failed'))

   end subroutine test_FieldsAreConformable

