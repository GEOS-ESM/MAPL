      end if
      call ESMF_VMBarrier(vm, rc=status)

   end subroutine test_make_geom_4pe_mixed_elements


   ! Test element distribution verification on 4 PEs
   @test(type=ESMF_TestMethod, npes=[4])
   subroutine test_make_geom_4pe_element_distribution(this)
      class(ESMF_TestMethod), intent(inout) :: this
      
      type(MeshGeomFactory) :: factory
      type(MeshGeomSpec) :: mesh_spec
      type(MeshDecomposition) :: decomp
      type(ESMF_Geom) :: geom
      type(ESMF_Mesh) :: mesh
      type(ESMF_VM) :: vm
      character(len=:), allocatable :: filename
      integer :: status
      integer :: localPet, petCount
      integer :: local_element_count, total_element_count
      integer :: i_start, i_end

      _UNUSED_DUMMY(this)

      ! Get VM info
      call ESMF_VMGetCurrent(vm, rc=status)
      call ESMF_VMGet(vm, localPet=localPet, petCount=petCount, rc=status)
      @assert_that(petCount, is(4))

      ! Create test mesh file
      filename = 'test_4pe_elem_dist.nc'
      if (localPet == 0) then
         call create_eight_element_mesh_file(filename, rc=status)
      end if
      call ESMF_VMBarrier(vm, rc=status)

      ! Create MeshGeomSpec
      decomp = MeshDecomposition(8, 15, petCount=4)  ! 8 elements, 15 nodes, 4 PEs
      mesh_spec = MeshGeomSpec(15, 8, decomp)
      call mesh_spec%set_filename(filename)

      ! Verify decomposition gives correct local indices
      call decomp%get_local_indices(localPet, i_start, i_end)
      total_element_count = i_end - i_start + 1
      @assert_that(total_element_count, is(2))

      ! Verify element indices are correct for each PE
      select case (localPet)
      case (0)
         @assert_that(i_start, is(1))
         @assert_that(i_end, is(2))
      case (1)
         @assert_that(i_start, is(3))
         @assert_that(i_end, is(4))
      case (2)
         @assert_that(i_start, is(5))
         @assert_that(i_end, is(6))
      case (3)
         @assert_that(i_start, is(7))
         @assert_that(i_end, is(8))
      end select

      ! Create geometry and verify distribution matches
      geom = factory%make_geom(mesh_spec, rc=status)
      @assert_that(status, is(0))

      call ESMF_GeomGet(geom, mesh=mesh, rc=status)
      @assert_that(status, is(0))

      call ESMF_MeshGet(mesh, elementCount=local_element_count, rc=status)
      @assert_that(status, is(0))
      @assert_that(local_element_count, is(2))

      ! Cleanup
      call ESMF_VMBarrier(vm, rc=status)
      call ESMF_GeomDestroy(geom, rc=status)
      call ESMF_VMBarrier(vm, rc=status)
      if (localPet == 0) then
         call cleanup_test_file(filename, rc=status)
      end if
      call ESMF_VMBarrier(vm, rc=status)

   end subroutine test_make_geom_4pe_element_distribution

end module Test_MeshGeomFactory_File
