#define I_AM_PFUNIT
#include "MAPL_ErrLog.h"

module Test_MeshGeomSpec
   use pfunit
   use esmf_TestMethod_mod ! mapl
   use mapl3g_MeshGeomSpec
   use mapl3g_MeshDecomposition
   use esmf
   implicit none

contains

   @test(type=ESMF_TestMethod, npes=[1])
   subroutine test_mesh_spec_creation(this)
      class(ESMF_TestMethod), intent(inout) :: this
      
      type(MeshGeomSpec) :: spec
      type(MeshDecomposition) :: decomp
      
      _UNUSED_DUMMY(this)
      
      ! Create a simple mesh spec: 4 nodes, 1 element
      decomp = MeshDecomposition([1])  ! Single element on one PE
      spec = MeshGeomSpec(4, 1, decomp)
      
      @assert_that(spec%get_nnodes(), is(4))
      @assert_that(spec%get_nelements(), is(1))
      
   end subroutine test_mesh_spec_creation

   @test(type=ESMF_TestMethod, npes=[1])
   subroutine test_mesh_spec_equality(this)
      class(ESMF_TestMethod), intent(inout) :: this
      
      type(MeshGeomSpec) :: spec1, spec2, spec3
      type(MeshDecomposition) :: decomp1, decomp2
      
      _UNUSED_DUMMY(this)
      
      decomp1 = MeshDecomposition([1])
      decomp2 = MeshDecomposition([2])
      
      spec1 = MeshGeomSpec(4, 1, decomp1)
      spec2 = MeshGeomSpec(4, 1, decomp1)
      spec3 = MeshGeomSpec(6, 2, decomp2)
      
      ! Test equality
      @assertTrue(spec1 == spec2)
      @assertFalse(spec1 == spec3)
      
   end subroutine test_mesh_spec_equality

   @test(type=ESMF_TestMethod, npes=[1])
   subroutine test_mesh_spec_with_filename(this)
      class(ESMF_TestMethod), intent(inout) :: this
      
      type(MeshGeomSpec) :: spec
      type(MeshDecomposition) :: decomp
      character(len=:), allocatable :: filename
      
      _UNUSED_DUMMY(this)
      
      ! Create a mesh spec with filename
      decomp = MeshDecomposition([1])
      spec = MeshGeomSpec(4, 1, decomp)
      
      ! Set filename
      call spec%set_filename('test_mesh.nc')
      
      ! Verify filename can be retrieved
      filename = spec%get_filename()
      @assertTrue(allocated(filename))
      @assert_that(trim(filename), is('test_mesh.nc'))
      
   end subroutine test_mesh_spec_with_filename

   @test(type=ESMF_TestMethod, npes=[1])
   subroutine test_supports_hconfig(this)
      class(ESMF_TestMethod), intent(inout) :: this
      
      type(ESMF_HConfig) :: hconfig
      type(MeshGeomSpec) :: spec
      type(MeshDecomposition) :: decomp
      integer :: status
      logical :: supports
      
      _UNUSED_DUMMY(this)
      
      ! Test valid mesh HConfig
      hconfig = ESMF_HConfigCreate(content="{class: mesh, file: 'dummy.nc'}", rc=status)
      @assert_that(status, is(0))
      
      decomp = MeshDecomposition([1])
      spec = MeshGeomSpec(1, 1, decomp)
      
      supports = spec%supports(hconfig, rc=status)
      @assert_that(status, is(0))
      @assertTrue(supports)
      
      call ESMF_HConfigDestroy(hconfig, rc=status)
      @assert_that(status, is(0))
      
      ! Test non-mesh HConfig
      hconfig = ESMF_HConfigCreate(content="{class: locstream, lon: [0.0], lat: [0.0]}", rc=status)
      @assert_that(status, is(0))
      
      supports = spec%supports(hconfig, rc=status)
      @assert_that(status, is(0))
      @assertFalse(supports)
      
      call ESMF_HConfigDestroy(hconfig, rc=status)
      @assert_that(status, is(0))
      
   end subroutine test_supports_hconfig

end module Test_MeshGeomSpec
