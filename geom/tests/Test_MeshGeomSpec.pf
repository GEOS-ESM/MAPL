#define I_AM_PFUNIT
#include "MAPL_ErrLog.h"

module Test_MeshGeomSpec
   use pfunit
   use esmf_TestMethod_mod ! mapl
   use mapl3g_MeshGeomSpec
   use mapl3g_MeshDecomposition
   use mapl3g_MeshTestHelper
   use esmf
   implicit none

contains

   @test(type=ESMF_TestMethod, npes=[1])
   subroutine test_mesh_spec_creation(this)
      class(ESMF_TestMethod), intent(inout) :: this
      
      type(MeshGeomSpec) :: spec
      type(MeshDecomposition) :: decomp
      character(len=256) :: filename
      integer :: status
      
      _UNUSED_DUMMY(this)
      
      ! Create mesh file
      filename = 'test_spec_creation.nc'
      call create_simple_quad_file(filename, rc=status)
      @assert_that(status, is(0))
      
      ! Create a simple mesh spec from file with explicit decomposition
      decomp = MeshDecomposition([1])  ! Single element on one PE
      spec = MeshGeomSpec(filename, decomposition=decomp, rc=status)
      @assert_that(status, is(0))
      
      @assert_that(spec%get_nnodes(), is(4))
      @assert_that(spec%get_nelements(), is(1))
      
      ! Clean up
      call cleanup_test_file(filename, rc=status)
      
   end subroutine test_mesh_spec_creation

   @test(type=ESMF_TestMethod, npes=[1])
   subroutine test_mesh_spec_equality(this)
      class(ESMF_TestMethod), intent(inout) :: this
      
      type(MeshGeomSpec) :: spec1, spec2, spec3
      type(MeshDecomposition) :: decomp1, decomp2
      character(len=256) :: filename1, filename2
      integer :: status
      
      _UNUSED_DUMMY(this)
      
      ! Create mesh files
      filename1 = 'test_equality_quad.nc'
      call create_simple_quad_file(filename1, rc=status)
      @assert_that(status, is(0))
      
      filename2 = 'test_equality_triangle.nc'
      call create_simple_triangle_file(filename2, rc=status)
      @assert_that(status, is(0))
      
      decomp1 = MeshDecomposition([1])
      decomp2 = MeshDecomposition([1])
      
      spec1 = MeshGeomSpec(filename1, decomposition=decomp1, rc=status)
      @assert_that(status, is(0))
      spec2 = MeshGeomSpec(filename1, decomposition=decomp1, rc=status)
      @assert_that(status, is(0))
      spec3 = MeshGeomSpec(filename2, decomposition=decomp2, rc=status)
      @assert_that(status, is(0))
      
      ! Test equality
      @assertTrue(spec1 == spec2)
      @assertFalse(spec1 == spec3)
      
      ! Clean up
      call cleanup_test_file(filename1, rc=status)
      call cleanup_test_file(filename2, rc=status)
      
   end subroutine test_mesh_spec_equality

   @test(type=ESMF_TestMethod, npes=[1])
   subroutine test_mesh_spec_with_filename(this)
      class(ESMF_TestMethod), intent(inout) :: this
      
      type(MeshGeomSpec) :: spec
      character(len=:), allocatable :: filename
      character(len=256) :: test_file
      integer :: status
      
      _UNUSED_DUMMY(this)
      
      ! Create mesh file
      test_file = 'test_with_filename.nc'
      call create_simple_quad_file(test_file, rc=status)
      @assert_that(status, is(0))
      
      ! Create a mesh spec from file (filename is automatically stored)
      spec = MeshGeomSpec(test_file, rc=status)
      @assert_that(status, is(0))
      
      ! Verify filename can be retrieved
      filename = spec%get_filename()
      @assertTrue(allocated(filename))
      @assert_that(trim(filename), is(trim(test_file)))
      
      ! Clean up
      call cleanup_test_file(test_file, rc=status)
      
   end subroutine test_mesh_spec_with_filename

   @test(type=ESMF_TestMethod, npes=[1])
   subroutine test_supports_hconfig(this)
      class(ESMF_TestMethod), intent(inout) :: this
      
      type(ESMF_HConfig) :: hconfig
      type(MeshGeomSpec) :: spec
      character(len=256) :: test_file
      integer :: status
      logical :: supports
      
      _UNUSED_DUMMY(this)
      
      ! Create a test mesh file
      test_file = 'test_supports.nc'
      call create_simple_quad_file(test_file, rc=status)
      @assert_that(status, is(0))
      
      ! Create spec from file
      spec = MeshGeomSpec(test_file, rc=status)
      @assert_that(status, is(0))
      
      ! Test valid mesh HConfig
      hconfig = ESMF_HConfigCreate(content="{class: mesh, file: 'dummy.nc'}", rc=status)
      @assert_that(status, is(0))
      
      supports = spec%supports(hconfig, rc=status)
      @assert_that(status, is(0))
      @assertTrue(supports)
      
      call ESMF_HConfigDestroy(hconfig, rc=status)
      @assert_that(status, is(0))
      
      ! Test non-mesh HConfig
      hconfig = ESMF_HConfigCreate(content="{class: locstream, lon: [0.0], lat: [0.0]}", rc=status)
      @assert_that(status, is(0))
      
      supports = spec%supports(hconfig, rc=status)
      @assert_that(status, is(0))
      @assertFalse(supports)
      
      call ESMF_HConfigDestroy(hconfig, rc=status)
      @assert_that(status, is(0))
      
      ! Clean up
      call cleanup_test_file(test_file, rc=status)
      
   end subroutine test_supports_hconfig

end module Test_MeshGeomSpec
